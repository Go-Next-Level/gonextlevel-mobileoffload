---
const faqs = [
  {
    q: "How does the revenue share work?",
    a: "Carrier revenue is split equally between Mobile Offload and the location partner — you receive 50% of all carrier payments generated by your network. There are no tiered structures, no sliding scales, and no fine print. Your share is paid by the 5th of each month with a full breakdown report.",
  },
  {
    q: "Does carrier offload affect my existing Wi-Fi performance?",
    a: "No. The carrier offload network runs on a completely separate SSID with dedicated bandwidth allocation. Your guest network, internal network, and POS systems are entirely untouched. We test for zero impact before going live.",
  },
  {
    q: "What carriers are supported?",
    a: "We currently support AT&T, T-Mobile, and Google Fi. These carriers use Passpoint (Hotspot 2.0) for automatic authentication — their subscribers connect seamlessly without any login screen or password.",
  },
  {
    q: "Do I need to buy new hardware?",
    a: "In most cases, no. If your existing access points support Passpoint / Hotspot 2.0 (most enterprise-grade hardware from Cisco, Aruba, Ruckus, Ubiquiti, and others do), we work with what you have. In some cases a single access point addition may be recommended — which we handle.",
  },
  {
    q: "How long does setup take?",
    a: "Approximately 1 hour. We work with your IT team or network administrator to configure a dedicated SSID, implement Passpoint and RadSec protocols, and run connectivity tests. We schedule during off-peak hours to minimize any disruption.",
  },
  {
    q: "What if I want to stop?",
    a: "Either party can exit with 30 days written notice. There are no termination fees, no penalties, and no minimum revenue requirements. On exit, we restore your network to its original configuration.",
  },
  {
    q: "How are revenue estimates calculated?",
    a: "Estimates are based on real deployment data from our active network, with a 20% conservative reduction applied. The primary variables are daily foot traffic and venue type — which reflects average dwell time and data usage patterns for that category. Actual results vary by location.",
  },
];
---
<section id="faq" class="py-24" style="background: var(--color-bg-base);">
  <div class="max-w-3xl mx-auto px-6">

    <div class="text-center mb-14">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full mb-6 text-xs font-semibold tracking-widest uppercase"
           style="background: var(--color-primary-muted); color: var(--color-accent); font-family: var(--font-body); border: 1px solid rgba(27,111,235,0.2);">
        FAQ
      </div>
      <h2 class="text-3xl lg:text-4xl font-bold" style="font-family: var(--font-display); letter-spacing: -0.02em;">
        Common Questions
      </h2>
    </div>

    <div class="flex flex-col gap-2" id="faq-list">
      {faqs.map((faq, i) => (
        <div class="faq-item rounded-xl overflow-hidden" style="background: var(--color-bg-surface); border: 1px solid var(--color-border);">
          <button
            type="button"
            class="faq-trigger w-full flex items-center justify-between gap-4 px-6 py-5 text-left cursor-pointer transition-colors duration-150"
            aria-expanded="false"
            aria-controls={`faq-answer-${i}`}
            id={`faq-trigger-${i}`}
          >
            <span class="text-base font-semibold" style="font-family: var(--font-display);">{faq.q}</span>
            <svg class="faq-chevron flex-shrink-0 transition-transform duration-200" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M6 9l6 6 6-6"/>
            </svg>
          </button>
          <div
            id={`faq-answer-${i}`}
            role="region"
            aria-labelledby={`faq-trigger-${i}`}
            class="faq-answer overflow-hidden"
            style="max-height: 0; transition: max-height 0.25s ease;"
          >
            <p class="px-6 pb-5 text-sm leading-relaxed" style="color: var(--color-text-secondary); font-family: var(--font-body);">{faq.a}</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .faq-trigger:hover {
    background: var(--color-bg-elevated);
  }
  .faq-item.open .faq-chevron {
    transform: rotate(180deg);
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('.faq-trigger').forEach(trigger => {
    trigger.addEventListener('click', () => {
      const item = trigger.closest('.faq-item') as HTMLElement;
      const answer = trigger.nextElementSibling as HTMLElement;
      const isOpen = item.classList.contains('open');

      // Close all
      document.querySelectorAll<HTMLElement>('.faq-item').forEach(el => {
        el.classList.remove('open');
        const ans = el.querySelector<HTMLElement>('.faq-answer');
        const btn = el.querySelector<HTMLButtonElement>('.faq-trigger');
        if (ans) ans.style.maxHeight = '0';
        if (btn) btn.setAttribute('aria-expanded', 'false');
      });

      // Open clicked (if it was closed)
      if (!isOpen) {
        item.classList.add('open');
        answer.style.maxHeight = answer.scrollHeight + 'px';
        trigger.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>
