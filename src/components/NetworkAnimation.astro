---
---
<section id="in-action" class="py-24 relative overflow-hidden" style="background: var(--color-bg-base);">
  <!-- Subtle radial bg -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true"
       style="background: radial-gradient(ellipse 60% 50% at 30% 50%, rgba(27,111,235,0.06) 0%, transparent 70%);"></div>

  <div class="max-w-7xl mx-auto px-6">
    <!-- Header -->
    <div class="text-center mb-14">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full mb-6 text-xs font-semibold tracking-widest uppercase"
           style="background: var(--color-primary-muted); color: var(--color-accent); font-family: var(--font-body); border: 1px solid rgba(27,111,235,0.2);">
        Live Demonstration
      </div>
      <h2 class="text-4xl lg:text-5xl font-bold mb-4" style="font-family: var(--font-display); letter-spacing: -0.02em;">
        Watch the Money Flow
      </h2>
      <p class="text-lg max-w-xl mx-auto" style="color: var(--color-text-secondary); font-family: var(--font-body);">
        Every time a carrier subscriber walks into your location, this is what happens — automatically.
      </p>
    </div>

    <div class="grid lg:grid-cols-5 gap-8 items-center">

      <!-- SVG Animation: 3 cols -->
      <div class="lg:col-span-3">
        <div class="relative rounded-2xl overflow-hidden" style="background: var(--color-bg-surface); border: 1px solid var(--color-border); aspect-ratio: 4/3;">
          <svg id="net-svg" viewBox="0 0 560 420" xmlns="http://www.w3.org/2000/svg" class="w-full h-full" aria-label="Network animation showing carrier offload flow" role="img">
            <defs>
              <!-- Glow filters -->
              <filter id="glow-blue" x="-50%" y="-50%" width="200%" height="200%">
                <feGaussianBlur stdDeviation="4" result="blur"/>
                <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
              </filter>
              <filter id="glow-green" x="-50%" y="-50%" width="200%" height="200%">
                <feGaussianBlur stdDeviation="5" result="blur"/>
                <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
              </filter>
              <filter id="glow-sm" x="-30%" y="-30%" width="160%" height="160%">
                <feGaussianBlur stdDeviation="2" result="blur"/>
                <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
              </filter>

              <!-- Gradients for connection lines -->
              <linearGradient id="grad-att" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" style="stop-color:#00A8E0; stop-opacity:0.8"/>
                <stop offset="100%" style="stop-color:#1B6FEB; stop-opacity:0.4"/>
              </linearGradient>
              <linearGradient id="grad-tmobile" x1="50%" y1="0%" x2="50%" y2="100%">
                <stop offset="0%" style="stop-color:#E20074; stop-opacity:0.8"/>
                <stop offset="100%" style="stop-color:#1B6FEB; stop-opacity:0.4"/>
              </linearGradient>
              <linearGradient id="grad-fi" x1="100%" y1="0%" x2="0%" y2="100%">
                <stop offset="0%" style="stop-color:#1A73E8; stop-opacity:0.8"/>
                <stop offset="100%" style="stop-color:#1B6FEB; stop-opacity:0.4"/>
              </linearGradient>
              <linearGradient id="grad-revenue" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" style="stop-color:#1B6FEB; stop-opacity:0.6"/>
                <stop offset="100%" style="stop-color:#10B981; stop-opacity:0.9"/>
              </linearGradient>
              <linearGradient id="grad-device" x1="0%" y1="100%" x2="100%" y2="0%">
                <stop offset="0%" style="stop-color:#7D99BE; stop-opacity:0.5"/>
                <stop offset="100%" style="stop-color:#1B6FEB; stop-opacity:0.8"/>
              </linearGradient>

              <!-- Venue gradient -->
              <radialGradient id="venue-fill" cx="50%" cy="50%" r="50%">
                <stop offset="0%" style="stop-color:#1B6FEB; stop-opacity:1"/>
                <stop offset="100%" style="stop-color:#0A3A9A; stop-opacity:1"/>
              </radialGradient>

              <!-- Venue glow -->
              <radialGradient id="venue-glow" cx="50%" cy="50%" r="50%">
                <stop offset="0%" style="stop-color:#1B6FEB; stop-opacity:0.3"/>
                <stop offset="100%" style="stop-color:#1B6FEB; stop-opacity:0"/>
              </radialGradient>

              <!-- Paths for animateMotion -->
              <path id="p-att"    d="M 110 95 Q 175 130 280 210"/>
              <path id="p-tmobile" d="M 280 68 L 280 210"/>
              <path id="p-fi"    d="M 450 95 Q 385 130 280 210"/>
              <path id="p-device" d="M 110 330 Q 185 280 280 210"/>
              <path id="p-revenue" d="M 280 210 Q 360 255 450 305"/>
            </defs>

            <!-- ── PULSE RINGS (venue) ── -->
            <circle class="pulse-ring r1" cx="280" cy="210" r="52" fill="none" stroke="#1B6FEB" stroke-width="1"/>
            <circle class="pulse-ring r2" cx="280" cy="210" r="52" fill="none" stroke="#1B6FEB" stroke-width="1"/>
            <circle class="pulse-ring r3" cx="280" cy="210" r="52" fill="none" stroke="#1B6FEB" stroke-width="1"/>

            <!-- ── VENUE GLOW HALO ── -->
            <circle cx="280" cy="210" r="80" fill="url(#venue-glow)"/>

            <!-- ── CONNECTION LINES (dashed) ── -->
            <!-- AT&T -->
            <path d="M 110 95 Q 175 130 280 210" stroke="url(#grad-att)" stroke-width="1.5" stroke-dasharray="5 4" fill="none" opacity="0.7" class="conn-line"/>
            <!-- T-Mobile -->
            <path d="M 280 68 L 280 210" stroke="url(#grad-tmobile)" stroke-width="1.5" stroke-dasharray="5 4" fill="none" opacity="0.7" class="conn-line"/>
            <!-- Google Fi -->
            <path d="M 450 95 Q 385 130 280 210" stroke="url(#grad-fi)" stroke-width="1.5" stroke-dasharray="5 4" fill="none" opacity="0.7" class="conn-line"/>
            <!-- Device -->
            <path d="M 110 330 Q 185 280 280 210" stroke="url(#grad-device)" stroke-width="1.5" stroke-dasharray="5 4" fill="none" opacity="0.5" class="conn-line" id="device-line"/>
            <!-- Revenue -->
            <path d="M 280 210 Q 360 255 450 305" stroke="url(#grad-revenue)" stroke-width="1.5" stroke-dasharray="5 4" fill="none" opacity="0.6" class="conn-line"/>

            <!-- ── TRAVELING PACKETS: AT&T → Venue ── -->
            <circle r="4.5" fill="#00A8E0" filter="url(#glow-sm)" opacity="0.9">
              <animateMotion dur="2.2s" repeatCount="indefinite" begin="0s"><mpath href="#p-att"/></animateMotion>
            </circle>
            <circle r="3.5" fill="#00A8E0" filter="url(#glow-sm)" opacity="0.7">
              <animateMotion dur="2.2s" repeatCount="indefinite" begin="0.7s"><mpath href="#p-att"/></animateMotion>
            </circle>
            <circle r="3" fill="#00A8E0" opacity="0.5">
              <animateMotion dur="2.2s" repeatCount="indefinite" begin="1.4s"><mpath href="#p-att"/></animateMotion>
            </circle>

            <!-- ── TRAVELING PACKETS: T-Mobile → Venue ── -->
            <circle r="4.5" fill="#E20074" filter="url(#glow-sm)" opacity="0.9">
              <animateMotion dur="1.9s" repeatCount="indefinite" begin="0.3s"><mpath href="#p-tmobile"/></animateMotion>
            </circle>
            <circle r="3.5" fill="#E20074" filter="url(#glow-sm)" opacity="0.7">
              <animateMotion dur="1.9s" repeatCount="indefinite" begin="1.0s"><mpath href="#p-tmobile"/></animateMotion>
            </circle>
            <circle r="3" fill="#E20074" opacity="0.5">
              <animateMotion dur="1.9s" repeatCount="indefinite" begin="1.6s"><mpath href="#p-tmobile"/></animateMotion>
            </circle>

            <!-- ── TRAVELING PACKETS: Google Fi → Venue ── -->
            <circle r="4.5" fill="#1A73E8" filter="url(#glow-sm)" opacity="0.9">
              <animateMotion dur="2.4s" repeatCount="indefinite" begin="0.5s"><mpath href="#p-fi"/></animateMotion>
            </circle>
            <circle r="3.5" fill="#1A73E8" filter="url(#glow-sm)" opacity="0.7">
              <animateMotion dur="2.4s" repeatCount="indefinite" begin="1.2s"><mpath href="#p-fi"/></animateMotion>
            </circle>
            <circle r="3" fill="#1A73E8" opacity="0.5">
              <animateMotion dur="2.4s" repeatCount="indefinite" begin="1.9s"><mpath href="#p-fi"/></animateMotion>
            </circle>

            <!-- ── TRAVELING PACKETS: Device → Venue ── -->
            <circle r="5" fill="#7D99BE" filter="url(#glow-sm)" opacity="0.8">
              <animateMotion dur="3s" repeatCount="indefinite" begin="0.8s"><mpath href="#p-device"/></animateMotion>
            </circle>
            <circle r="3.5" fill="#7D99BE" opacity="0.5">
              <animateMotion dur="3s" repeatCount="indefinite" begin="2.3s"><mpath href="#p-device"/></animateMotion>
            </circle>

            <!-- ── TRAVELING PACKETS: Venue → Revenue ($) ── -->
            <circle r="5" fill="#10B981" filter="url(#glow-sm)" opacity="0.95">
              <animateMotion dur="1.8s" repeatCount="indefinite" begin="1.1s"><mpath href="#p-revenue"/></animateMotion>
            </circle>
            <circle r="4" fill="#10B981" filter="url(#glow-sm)" opacity="0.8">
              <animateMotion dur="1.8s" repeatCount="indefinite" begin="2.0s"><mpath href="#p-revenue"/></animateMotion>
            </circle>
            <circle r="3" fill="#10B981" opacity="0.6">
              <animateMotion dur="1.8s" repeatCount="indefinite" begin="2.9s"><mpath href="#p-revenue"/></animateMotion>
            </circle>

            <!-- ── VENUE CENTER NODE ── -->
            <!-- Outer ring -->
            <circle cx="280" cy="210" r="46" fill="none" stroke="#1B6FEB" stroke-width="1.5" opacity="0.4"/>
            <!-- Main circle -->
            <circle cx="280" cy="210" r="38" fill="url(#venue-fill)" filter="url(#glow-blue)"/>
            <!-- Wi-Fi icon inside venue -->
            <g transform="translate(262, 196)" fill="none" stroke="white" stroke-width="2.2" stroke-linecap="round">
              <path d="M 18 28 Q 18 22 24 18 Q 30 14 36 18 Q 42 22 42 28" opacity="0.5"/>
              <path d="M 13 23 Q 13 14 24 8 Q 35 2 47 8 Q 58 14 58 23" opacity="0.3"/>
              <circle cx="30" cy="28" r="2.5" fill="white" stroke="none"/>
            </g>
            <!-- Venue label -->
            <text x="280" y="262" text-anchor="middle" fill="white" font-size="11" font-family="var(--font-display)" font-weight="600" opacity="0.9">YOUR LOCATION</text>

            <!-- ── AT&T NODE ── -->
            <circle cx="110" cy="95" r="32" fill="#081828" stroke="#00A8E0" stroke-width="1.5" opacity="0.9" filter="url(#glow-sm)"/>
            <text x="110" y="91" text-anchor="middle" fill="#00A8E0" font-size="11" font-family="var(--font-display)" font-weight="700">AT&amp;T</text>
            <text x="110" y="108" text-anchor="middle" fill="#7D99BE" font-size="8.5" font-family="var(--font-body)">Carrier</text>

            <!-- ── T-MOBILE NODE ── -->
            <circle cx="280" cy="55" r="32" fill="#1A0818" stroke="#E20074" stroke-width="1.5" opacity="0.9" filter="url(#glow-sm)"/>
            <text x="280" y="51" text-anchor="middle" fill="#E20074" font-size="10" font-family="var(--font-display)" font-weight="700">T-Mobile</text>
            <text x="280" y="67" text-anchor="middle" fill="#7D99BE" font-size="8.5" font-family="var(--font-body)">Carrier</text>

            <!-- ── GOOGLE FI NODE ── -->
            <circle cx="450" cy="95" r="32" fill="#081020" stroke="#1A73E8" stroke-width="1.5" opacity="0.9" filter="url(#glow-sm)"/>
            <text x="450" y="91" text-anchor="middle" fill="#1A73E8" font-size="10" font-family="var(--font-display)" font-weight="700">Google</text>
            <text x="450" y="103" text-anchor="middle" fill="#1A73E8" font-size="10" font-family="var(--font-display)" font-weight="700">Fi</text>
            <text x="450" y="118" text-anchor="middle" fill="#7D99BE" font-size="8.5" font-family="var(--font-body)">Carrier</text>

            <!-- ── SUBSCRIBER DEVICE NODE ── -->
            <circle cx="110" cy="330" r="30" fill="#091424" stroke="rgba(125,153,190,0.6)" stroke-width="1.5"/>
            <!-- Phone icon -->
            <rect x="97" y="315" width="26" height="33" rx="4" fill="none" stroke="#7D99BE" stroke-width="1.8"/>
            <rect x="102" y="320" width="16" height="20" rx="1.5" fill="rgba(27,111,235,0.25)"/>
            <circle cx="110" cy="345" r="2" fill="#7D99BE"/>
            <text x="110" y="374" text-anchor="middle" fill="#7D99BE" font-size="9" font-family="var(--font-body)">Subscriber</text>

            <!-- ── REVENUE NODE ── -->
            <circle cx="450" cy="310" r="36" fill="#071A0F" stroke="#10B981" stroke-width="1.5" filter="url(#glow-green)" opacity="0.95"/>
            <!-- Dollar sign -->
            <text x="450" y="303" text-anchor="middle" fill="#10B981" font-size="20" font-family="var(--font-mono)" font-weight="700">$</text>
            <!-- Live counter -->
            <text id="rev-counter" x="450" y="320" text-anchor="middle" fill="#10B981" font-size="10.5" font-family="var(--font-mono)" font-weight="600">0.00</text>
            <text x="450" y="335" text-anchor="middle" fill="#7D99BE" font-size="8.5" font-family="var(--font-body)">Your Revenue</text>

            <!-- ── STEP LABELS on paths ── -->
            <!-- Auth label near center of AT&T line -->
            <g transform="translate(185, 148)">
              <rect x="-26" y="-10" width="52" height="18" rx="5" fill="rgba(0,168,224,0.12)" stroke="rgba(0,168,224,0.3)" stroke-width="1"/>
              <text text-anchor="middle" y="3" fill="#00A8E0" font-size="8" font-family="var(--font-body)">Auto-auth</text>
            </g>
            <!-- Data label near revenue line midpoint -->
            <g transform="translate(370, 262)">
              <rect x="-26" y="-10" width="52" height="18" rx="5" fill="rgba(16,185,129,0.12)" stroke="rgba(16,185,129,0.3)" stroke-width="1"/>
              <text text-anchor="middle" y="3" fill="#10B981" font-size="8" font-family="var(--font-body)">Revenue</text>
            </g>

          </svg>

          <!-- Live status badge -->
          <div class="absolute top-4 left-4 flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-semibold"
               style="background: rgba(16,185,129,0.12); border: 1px solid rgba(16,185,129,0.3); color: #10B981; font-family: var(--font-body);">
            <span class="w-2 h-2 rounded-full" style="background: #10B981; animation: ping 1.5s ease-in-out infinite;"></span>
            Live Network
          </div>
        </div>
      </div>

      <!-- Step panel: 2 cols -->
      <div class="lg:col-span-2 flex flex-col gap-3">
        <div class="step-card active p-5 rounded-xl cursor-default transition-all duration-300" data-step="0">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0 step-icon" style="background: var(--color-primary-muted); border: 1px solid rgba(27,111,235,0.3);">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1B6FEB" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
            <div>
              <div class="step-num text-xs font-bold mb-1" style="color: var(--color-primary); font-family: var(--font-body); text-transform: uppercase; letter-spacing: 0.08em;">Step 01</div>
              <h3 class="text-base font-bold mb-1" style="font-family: var(--font-display);">Subscriber Enters Your Location</h3>
              <p class="text-sm leading-relaxed" style="color: var(--color-text-secondary); font-family: var(--font-body);">An AT&T, T-Mobile, or Google Fi customer walks through your door. Their phone detects your Passpoint-enabled network.</p>
            </div>
          </div>
          <div class="step-progress mt-4 h-0.5 rounded-full overflow-hidden" style="background: var(--color-border);">
            <div class="step-bar h-full rounded-full" style="background: var(--color-primary); width: 0%;"></div>
          </div>
        </div>

        <div class="step-card p-5 rounded-xl cursor-default transition-all duration-300" data-step="1">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0 step-icon" style="background: var(--color-bg-elevated); border: 1px solid var(--color-border);">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-text-muted)" stroke-width="2" stroke-linecap="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            </div>
            <div>
              <div class="step-num text-xs font-bold mb-1" style="color: var(--color-text-muted); font-family: var(--font-body); text-transform: uppercase; letter-spacing: 0.08em;">Step 02</div>
              <h3 class="text-base font-bold mb-1" style="font-family: var(--font-display);">Device Authenticates Silently</h3>
              <p class="text-sm leading-relaxed" style="color: var(--color-text-secondary); font-family: var(--font-body);">The carrier verifies their identity in the background using RadSec. No login screen, no password — completely seamless.</p>
            </div>
          </div>
          <div class="step-progress mt-4 h-0.5 rounded-full overflow-hidden" style="background: var(--color-border);">
            <div class="step-bar h-full rounded-full" style="background: var(--color-primary); width: 0%;"></div>
          </div>
        </div>

        <div class="step-card p-5 rounded-xl cursor-default transition-all duration-300" data-step="2">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0 step-icon" style="background: var(--color-bg-elevated); border: 1px solid var(--color-border);">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-text-muted)" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M5 12.55a11 11 0 0 1 14.08 0"/><path d="M1.42 9a16 16 0 0 1 21.16 0"/><path d="M8.53 16.11a6 6 0 0 1 6.95 0"/><circle cx="12" cy="20" r="1" fill="currentColor"/></svg>
            </div>
            <div>
              <div class="step-num text-xs font-bold mb-1" style="color: var(--color-text-muted); font-family: var(--font-body); text-transform: uppercase; letter-spacing: 0.08em;">Step 03</div>
              <h3 class="text-base font-bold mb-1" style="font-family: var(--font-display);">Their Data Flows Through Your Wi-Fi</h3>
              <p class="text-sm leading-relaxed" style="color: var(--color-text-secondary); font-family: var(--font-body);">Social media, video, calls — all their mobile data routes through your network. The carrier tracks every megabyte.</p>
            </div>
          </div>
          <div class="step-progress mt-4 h-0.5 rounded-full overflow-hidden" style="background: var(--color-border);">
            <div class="step-bar h-full rounded-full" style="background: var(--color-primary); width: 0%;"></div>
          </div>
        </div>

        <div class="step-card p-5 rounded-xl cursor-default transition-all duration-300" data-step="3">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0 step-icon" style="background: rgba(16,185,129,0.1); border: 1px solid rgba(16,185,129,0.2);">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-text-muted)" stroke-width="2" stroke-linecap="round" aria-hidden="true"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
            </div>
            <div>
              <div class="step-num text-xs font-bold mb-1" style="color: var(--color-text-muted); font-family: var(--font-body); text-transform: uppercase; letter-spacing: 0.08em;">Step 04</div>
              <h3 class="text-base font-bold mb-1" style="font-family: var(--font-display);">You Get Paid</h3>
              <p class="text-sm leading-relaxed" style="color: var(--color-text-secondary); font-family: var(--font-body);">The carrier pays per GB offloaded. This happens with every subscriber, every visit, every day — adding up to your monthly payment.</p>
            </div>
          </div>
          <div class="step-progress mt-4 h-0.5 rounded-full overflow-hidden" style="background: var(--color-border);">
            <div class="step-bar h-full rounded-full" style="background: var(--color-success); width: 0%;"></div>
          </div>
        </div>

        <a href="#qualify" class="mt-2 flex items-center justify-center gap-2 py-3.5 rounded-xl font-semibold text-sm text-white transition-all duration-200 cursor-pointer"
           style="background: var(--color-primary); font-family: var(--font-body);"
           onmouseover="this.style.background='var(--color-primary-hover)'"
           onmouseout="this.style.background='var(--color-primary)'">
          See If Your Location Qualifies
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .step-card {
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border);
  }
  .step-card.active {
    background: var(--color-bg-card);
    border-color: var(--color-border-bright);
    box-shadow: 0 0 0 1px rgba(27,111,235,0.15), 0 4px 20px rgba(27,111,235,0.08);
  }
  .step-card.active .step-icon {
    background: var(--color-primary-muted) !important;
    border-color: rgba(27,111,235,0.3) !important;
  }
  .step-card.active .step-icon svg {
    stroke: var(--color-primary) !important;
  }
  .step-card[data-step="3"].active .step-icon svg {
    stroke: var(--color-success) !important;
  }
  .step-card.active .step-num {
    color: var(--color-primary) !important;
  }
  .step-card[data-step="3"].active .step-num {
    color: var(--color-success) !important;
  }

  /* Pulse rings */
  .pulse-ring {
    transform-origin: 280px 210px;
    animation: pulse-expand 3s ease-out infinite;
  }
  .pulse-ring.r2 { animation-delay: 1s; }
  .pulse-ring.r3 { animation-delay: 2s; }

  @keyframes pulse-expand {
    0%   { r: 42; opacity: 0.6; }
    100% { r: 90; opacity: 0; }
  }

  @keyframes ping {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(1.4); }
  }

  /* Step bar fill animation */
  @keyframes fill-bar {
    from { width: 0%; }
    to   { width: 100%; }
  }
  .step-bar.animating {
    animation: fill-bar linear forwards;
  }
</style>

<script>
  const STEP_DURATION = 3000; // ms each step stays active
  const steps = Array.from(document.querySelectorAll<HTMLElement>('.step-card'));
  let current = 0;
  let timer: ReturnType<typeof setTimeout>;

  function activateStep(idx: number): void {
    steps.forEach((s, i) => {
      s.classList.toggle('active', i === idx);
      const bar = s.querySelector<HTMLElement>('.step-bar');
      if (bar) {
        bar.style.animation = 'none';
        bar.style.width = '0%';
        void bar.offsetWidth; // reflow
        if (i === idx) {
          bar.style.animation = `fill-bar ${STEP_DURATION}ms linear forwards`;
        }
      }
    });
  }

  function nextStep(): void {
    current = (current + 1) % steps.length;
    activateStep(current);
    timer = setTimeout(nextStep, STEP_DURATION);
  }

  // Start
  activateStep(0);
  timer = setTimeout(nextStep, STEP_DURATION);

  // Click to jump
  steps.forEach((card, idx) => {
    card.addEventListener('click', () => {
      clearTimeout(timer);
      current = idx;
      activateStep(current);
      timer = setTimeout(nextStep, STEP_DURATION);
    });
  });

  // Revenue counter
  const revEl = document.getElementById('rev-counter');
  let revValue = 0;
  const TARGET = 47.82;
  const TICK_MS = 50;
  const INCREMENT = TARGET / (8000 / TICK_MS); // reach target over ~8s then reset

  function tickRevenue(): void {
    revValue += INCREMENT;
    if (revValue >= TARGET) revValue = 0;
    if (revEl) revEl.textContent = revValue.toFixed(2);
  }
  setInterval(tickRevenue, TICK_MS);
</script>
