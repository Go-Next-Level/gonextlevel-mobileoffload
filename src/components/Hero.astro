---
---
<section class="relative min-h-screen flex items-center overflow-hidden grid-texture" style="padding-top: 4rem;" aria-label="Hero">
  <!-- Background radial glow -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[800px] h-[600px] rounded-full opacity-20"
         style="background: radial-gradient(ellipse at center, #1B6FEB 0%, transparent 70%); filter: blur(80px);"></div>
    <div class="absolute bottom-0 right-0 w-[400px] h-[400px] rounded-full opacity-10"
         style="background: radial-gradient(ellipse at center, #0EA5E9 0%, transparent 70%); filter: blur(60px);"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-6 py-24 w-full">
    <div class="grid lg:grid-cols-2 gap-16 items-center">

      <!-- Left: Content -->
      <div>
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full mb-8 text-sm font-medium"
             style="background: var(--color-primary-muted); border: 1px solid rgba(27, 111, 235, 0.3); color: var(--color-accent); font-family: var(--font-body);">
          <span class="w-2 h-2 rounded-full animate-pulse-ring" style="background: var(--color-accent);"></span>
          Carrier Offload Network Partnership
        </div>

        <!-- Headline -->
        <h1 class="text-5xl lg:text-6xl xl:text-7xl font-bold mb-6 leading-tight" style="font-family: var(--font-display); letter-spacing: -0.02em;">
          Your Wi-Fi Is<br/>
          <span class="gradient-text">Leaving Money</span><br/>
          on the Table
        </h1>

        <p class="text-lg mb-10 max-w-lg" style="color: var(--color-text-secondary); line-height: 1.7; font-family: var(--font-body);">
          Partner with Mobile Offload to monetize your existing Wi-Fi infrastructure. AT&T, T-Mobile, and Google Fi pay you every time their subscribers connect through your network — zero hardware, zero setup fees.
        </p>

        <!-- Stats row -->
        <div class="flex flex-wrap gap-8 mb-10">
          <div>
            <div class="text-3xl font-bold" style="font-family: var(--font-mono); color: var(--color-success);">555%</div>
            <div class="text-sm mt-1" style="color: var(--color-text-muted); font-family: var(--font-body);">Network Growth Q3→Q4 2025</div>
          </div>
          <div style="width: 1px; background: var(--color-border);"></div>
          <div>
            <div class="text-3xl font-bold" style="font-family: var(--font-mono); color: var(--color-success);">124K+</div>
            <div class="text-sm mt-1" style="color: var(--color-text-muted); font-family: var(--font-body);">Active Subscribers</div>
          </div>
          <div style="width: 1px; background: var(--color-border);"></div>
          <div>
            <div class="text-3xl font-bold" style="font-family: var(--font-mono); color: var(--color-success);">$0</div>
            <div class="text-sm mt-1" style="color: var(--color-text-muted); font-family: var(--font-body);">Upfront Cost</div>
          </div>
        </div>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="#qualify"
             class="inline-flex items-center justify-center gap-2 px-7 py-4 rounded-xl text-base font-semibold text-white transition-all duration-200 cursor-pointer"
             style="background: var(--color-primary); font-family: var(--font-body);"
             onmouseover="this.style.background='var(--color-primary-hover)'; this.style.transform='translateY(-1px)'; this.style.boxShadow='0 8px 32px rgba(27,111,235,0.4)'"
             onmouseout="this.style.background='var(--color-primary)'; this.style.transform='none'; this.style.boxShadow='none'">
            Check If You Qualify
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
          <a href="#revenue"
             class="inline-flex items-center justify-center gap-2 px-7 py-4 rounded-xl text-base font-medium transition-all duration-200 cursor-pointer"
             style="background: transparent; border: 1px solid var(--color-border-bright); color: var(--color-text-secondary); font-family: var(--font-body);"
             onmouseover="this.style.borderColor='var(--color-primary)'; this.style.color='var(--color-text-primary)'"
             onmouseout="this.style.borderColor='var(--color-border-bright)'; this.style.color='var(--color-text-secondary)'">
            Calculate Revenue
          </a>
        </div>
      </div>

      <!-- Right: Live network animation -->
      <div class="relative hidden lg:block" aria-hidden="true">
        <div class="relative rounded-2xl overflow-hidden" style="background: var(--color-bg-surface); border: 1px solid var(--color-border);">
          <svg id="hero-svg" viewBox="0 0 480 370" xmlns="http://www.w3.org/2000/svg" class="w-full" aria-label="Live carrier offload network diagram" role="img">
            <defs>
              <filter id="hglow-blue" x="-50%" y="-50%" width="200%" height="200%">
                <feGaussianBlur stdDeviation="3.5" result="blur"/>
                <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
              </filter>
              <filter id="hglow-green" x="-50%" y="-50%" width="200%" height="200%">
                <feGaussianBlur stdDeviation="5" result="blur"/>
                <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
              </filter>
              <filter id="hglow-sm" x="-30%" y="-30%" width="160%" height="160%">
                <feGaussianBlur stdDeviation="2.5" result="blur"/>
                <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
              </filter>

              <linearGradient id="hgrad-att" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" style="stop-color:#00A8E0;stop-opacity:0.9"/>
                <stop offset="100%" style="stop-color:#1B6FEB;stop-opacity:0.35"/>
              </linearGradient>
              <linearGradient id="hgrad-tmobile" x1="50%" y1="0%" x2="50%" y2="100%">
                <stop offset="0%" style="stop-color:#E20074;stop-opacity:0.9"/>
                <stop offset="100%" style="stop-color:#1B6FEB;stop-opacity:0.35"/>
              </linearGradient>
              <linearGradient id="hgrad-fi" x1="100%" y1="0%" x2="0%" y2="100%">
                <stop offset="0%" style="stop-color:#1A73E8;stop-opacity:0.9"/>
                <stop offset="100%" style="stop-color:#1B6FEB;stop-opacity:0.35"/>
              </linearGradient>
              <linearGradient id="hgrad-rev" x1="0%" y1="0%" x2="0%" y2="100%">
                <stop offset="0%" style="stop-color:#1B6FEB;stop-opacity:0.6"/>
                <stop offset="100%" style="stop-color:#10B981;stop-opacity:0.9"/>
              </linearGradient>

              <radialGradient id="hbuilding-glow" cx="50%" cy="40%" r="50%">
                <stop offset="0%" style="stop-color:#1B6FEB;stop-opacity:0.22"/>
                <stop offset="100%" style="stop-color:#1B6FEB;stop-opacity:0"/>
              </radialGradient>

              <!-- Motion paths: carriers flow TOP → DOWN to building -->
              <path id="h-att"      d="M 88 66 C 140 116 185 152 227 166"/>
              <path id="h-tmobile"  d="M 240 47 L 240 149"/>
              <path id="h-fi"       d="M 392 66 C 340 116 295 152 253 166"/>
              <path id="h-rev"      d="M 240 218 L 240 280"/>
            </defs>

            <!-- carrier row label -->
            <text x="240" y="18" text-anchor="middle" fill="rgba(125,153,190,0.45)" font-size="7.5" font-family="var(--font-body)" font-weight="600" letter-spacing="0.12em">CARRIER NETWORK</text>

            <!-- Connection lines -->
            <path d="M 88 66 C 140 116 185 152 227 166" stroke="url(#hgrad-att)" stroke-width="1.5" stroke-dasharray="5 4" fill="none" opacity="0.55"/>
            <path d="M 240 47 L 240 149" stroke="url(#hgrad-tmobile)" stroke-width="1.5" stroke-dasharray="5 4" fill="none" opacity="0.55"/>
            <path d="M 392 66 C 340 116 295 152 253 166" stroke="url(#hgrad-fi)" stroke-width="1.5" stroke-dasharray="5 4" fill="none" opacity="0.55"/>
            <path d="M 240 218 L 240 280" stroke="url(#hgrad-rev)" stroke-width="2" stroke-dasharray="4 3" fill="none" opacity="0.65"/>

            <!-- Pulse rings (centered on building ~240, 188) -->
            <circle class="hero-pulse hp1" cx="240" cy="188" r="46" fill="none" stroke="#1B6FEB" stroke-width="1"/>
            <circle class="hero-pulse hp2" cx="240" cy="188" r="46" fill="none" stroke="#1B6FEB" stroke-width="1"/>
            <circle class="hero-pulse hp3" cx="240" cy="188" r="46" fill="none" stroke="#1B6FEB" stroke-width="1"/>

            <!-- Building glow -->
            <ellipse cx="240" cy="196" rx="66" ry="54" fill="url(#hbuilding-glow)"/>

            <!-- ── BUILDING ICON (centered ~240, 190) ── -->
            <!-- Rooftop antenna -->
            <line x1="240" y1="140" x2="240" y2="150" stroke="#1B6FEB" stroke-width="1.8" stroke-linecap="round"/>
            <circle cx="240" cy="138" r="2.2" fill="#1B6FEB" opacity="0.85"/>
            <!-- Wi-Fi arcs -->
            <path d="M 233 146 Q 240 140 247 146" stroke="#1B6FEB" stroke-width="1.4" fill="none" stroke-linecap="round" opacity="0.7"/>
            <path d="M 228 149 Q 240 141 252 149" stroke="#1B6FEB" stroke-width="1.1" fill="none" stroke-linecap="round" opacity="0.4"/>

            <!-- Top floor -->
            <rect x="213" y="150" width="54" height="18" rx="1.5" fill="rgba(8,36,90,0.92)" stroke="#1B6FEB" stroke-width="1.5"/>
            <rect x="218" y="153" width="10" height="11" rx="1.5" fill="rgba(14,165,233,0.65)" stroke="rgba(14,165,233,0.3)" stroke-width="0.7"/>
            <rect x="234" y="153" width="10" height="11" rx="1.5" fill="rgba(14,165,233,0.9)" stroke="rgba(14,165,233,0.4)" stroke-width="0.7"/>
            <rect x="250" y="153" width="10" height="11" rx="1.5" fill="rgba(14,165,233,0.5)" stroke="rgba(14,165,233,0.3)" stroke-width="0.7"/>

            <!-- Mid floor -->
            <rect x="208" y="167" width="64" height="20" rx="1.5" fill="rgba(10,42,108,0.92)" stroke="#1B6FEB" stroke-width="1.5"/>
            <rect x="213" y="171" width="11" height="12" rx="1.5" fill="rgba(14,165,233,0.45)" stroke="rgba(14,165,233,0.2)" stroke-width="0.7"/>
            <rect x="230" y="171" width="11" height="12" rx="1.5" fill="rgba(14,165,233,0.75)" stroke="rgba(14,165,233,0.35)" stroke-width="0.7"/>
            <rect x="247" y="171" width="11" height="12" rx="1.5" fill="rgba(14,165,233,0.5)" stroke="rgba(14,165,233,0.25)" stroke-width="0.7"/>
            <rect x="263" y="171" width="6" height="12" rx="1.5" fill="rgba(14,165,233,0.3)" stroke="rgba(14,165,233,0.15)" stroke-width="0.7"/>

            <!-- Ground floor -->
            <rect x="203" y="186" width="74" height="24" rx="1.5" fill="rgba(12,48,118,0.92)" stroke="#1B6FEB" stroke-width="1.5"/>
            <rect x="207" y="190" width="15" height="15" rx="1.5" fill="rgba(14,165,233,0.4)" stroke="rgba(14,165,233,0.2)" stroke-width="0.7"/>
            <rect x="228" y="190" width="15" height="15" rx="1.5" fill="rgba(14,165,233,0.3)" stroke="rgba(14,165,233,0.2)" stroke-width="0.7"/>
            <!-- Door -->
            <rect x="249" y="195" width="16" height="15" rx="2" fill="rgba(27,111,235,0.45)" stroke="#1B6FEB" stroke-width="1.1"/>
            <circle cx="263" cy="202" r="1.6" fill="#1B6FEB" opacity="0.9"/>
            <rect x="271" y="190" width="4" height="15" rx="1" fill="rgba(14,165,233,0.3)" stroke="rgba(14,165,233,0.15)" stroke-width="0.5"/>

            <!-- "YOUR LOCATION" label -->
            <text x="240" y="225" text-anchor="middle" fill="rgba(255,255,255,0.72)" font-size="9" font-family="var(--font-display)" font-weight="600" letter-spacing="0.06em">YOUR LOCATION</text>

            <!-- Revenue pill -->
            <rect x="182" y="283" width="116" height="52" rx="12" fill="rgba(4,18,12,0.96)" stroke="#10B981" stroke-width="1.8" filter="url(#hglow-green)"/>
            <text x="240" y="300" text-anchor="middle" fill="rgba(16,185,129,0.6)" font-size="7.5" font-family="var(--font-body)" font-weight="700" letter-spacing="0.1em">REVENUE EARNED</text>
            <text id="hero-rev" x="240" y="324" text-anchor="middle" fill="#10B981" font-size="21" font-family="var(--font-mono)" font-weight="700">$0.00</text>

            <!-- Traveling packets: AT&T → Building -->
            <circle r="4" fill="#00A8E0" filter="url(#hglow-sm)" opacity="0.9">
              <animateMotion dur="2.2s" repeatCount="indefinite" begin="0s"><mpath href="#h-att"/></animateMotion>
            </circle>
            <circle r="3" fill="#00A8E0" filter="url(#hglow-sm)" opacity="0.65">
              <animateMotion dur="2.2s" repeatCount="indefinite" begin="0.8s"><mpath href="#h-att"/></animateMotion>
            </circle>
            <circle r="2.2" fill="#00A8E0" opacity="0.4">
              <animateMotion dur="2.2s" repeatCount="indefinite" begin="1.6s"><mpath href="#h-att"/></animateMotion>
            </circle>

            <!-- Traveling packets: T-Mobile → Building -->
            <circle r="4" fill="#E20074" filter="url(#hglow-sm)" opacity="0.9">
              <animateMotion dur="1.9s" repeatCount="indefinite" begin="0.3s"><mpath href="#h-tmobile"/></animateMotion>
            </circle>
            <circle r="3" fill="#E20074" filter="url(#hglow-sm)" opacity="0.65">
              <animateMotion dur="1.9s" repeatCount="indefinite" begin="1.0s"><mpath href="#h-tmobile"/></animateMotion>
            </circle>
            <circle r="2.2" fill="#E20074" opacity="0.4">
              <animateMotion dur="1.9s" repeatCount="indefinite" begin="1.6s"><mpath href="#h-tmobile"/></animateMotion>
            </circle>

            <!-- Traveling packets: Google Fi → Building -->
            <circle r="4" fill="#1A73E8" filter="url(#hglow-sm)" opacity="0.9">
              <animateMotion dur="2.4s" repeatCount="indefinite" begin="0.5s"><mpath href="#h-fi"/></animateMotion>
            </circle>
            <circle r="3" fill="#1A73E8" filter="url(#hglow-sm)" opacity="0.65">
              <animateMotion dur="2.4s" repeatCount="indefinite" begin="1.3s"><mpath href="#h-fi"/></animateMotion>
            </circle>
            <circle r="2.2" fill="#1A73E8" opacity="0.4">
              <animateMotion dur="2.4s" repeatCount="indefinite" begin="2.0s"><mpath href="#h-fi"/></animateMotion>
            </circle>

            <!-- Traveling packets: Building → Revenue -->
            <circle r="5" fill="#10B981" filter="url(#hglow-sm)" opacity="0.95">
              <animateMotion dur="1.5s" repeatCount="indefinite" begin="1.2s"><mpath href="#h-rev"/></animateMotion>
            </circle>
            <circle r="3.5" fill="#10B981" filter="url(#hglow-sm)" opacity="0.75">
              <animateMotion dur="1.5s" repeatCount="indefinite" begin="2.1s"><mpath href="#h-rev"/></animateMotion>
            </circle>

            <!-- AT&T node -->
            <circle cx="88" cy="66" r="28" fill="#060F18" stroke="#00A8E0" stroke-width="1.5" filter="url(#hglow-sm)"/>
            <text x="88" y="62" text-anchor="middle" fill="#00A8E0" font-size="10" font-family="var(--font-display)" font-weight="700">AT&amp;T</text>
            <text x="88" y="77" text-anchor="middle" fill="rgba(125,153,190,0.65)" font-size="8" font-family="var(--font-body)">Carrier</text>

            <!-- T-Mobile node -->
            <circle cx="240" cy="47" r="28" fill="#120010" stroke="#E20074" stroke-width="1.5" filter="url(#hglow-sm)"/>
            <text x="240" y="43" text-anchor="middle" fill="#E20074" font-size="9.5" font-family="var(--font-display)" font-weight="700">T-Mobile</text>
            <text x="240" y="58" text-anchor="middle" fill="rgba(125,153,190,0.65)" font-size="8" font-family="var(--font-body)">Carrier</text>

            <!-- Google Fi node -->
            <circle cx="392" cy="66" r="28" fill="#060C18" stroke="#1A73E8" stroke-width="1.5" filter="url(#hglow-sm)"/>
            <text x="392" y="58" text-anchor="middle" fill="#1A73E8" font-size="9.5" font-family="var(--font-display)" font-weight="700">Google</text>
            <text x="392" y="71" text-anchor="middle" fill="#1A73E8" font-size="9.5" font-family="var(--font-display)" font-weight="700">Fi</text>
            <text x="392" y="84" text-anchor="middle" fill="rgba(125,153,190,0.65)" font-size="8" font-family="var(--font-body)">Carrier</text>

          </svg>

          <!-- Live badge -->
          <div class="absolute top-3 left-3 flex items-center gap-2 px-2.5 py-1 rounded-full text-xs font-semibold"
               style="background: rgba(16,185,129,0.12); border: 1px solid rgba(16,185,129,0.3); color: #10B981; font-family: var(--font-body);">
            <span class="hero-ping w-1.5 h-1.5 rounded-full" style="background: #10B981;"></span>
            Live
          </div>
        </div>
      </div>

    </div>

    <!-- Partner logos -->
    <div class="mt-20 pt-12" style="border-top: 1px solid var(--color-border);">
      <p class="text-xs font-semibold tracking-widest uppercase mb-8 text-center" style="color: var(--color-text-muted); font-family: var(--font-body);">
        Carrier Partners
      </p>
      <div class="flex flex-wrap items-center justify-center gap-12">

        <!-- AT&T globe -->
        <svg width="130" height="52" viewBox="0 0 130 52" fill="none" aria-label="AT&T">
          <defs>
            <clipPath id="att-globe-clip"><circle cx="26" cy="26" r="23"/></clipPath>
          </defs>
          <circle cx="26" cy="26" r="24" fill="#009FDB"/>
          <g clip-path="url(#att-globe-clip)" stroke="white" fill="none">
            <line x1="2" y1="9"  x2="50" y2="9"  stroke-width="1.6"/>
            <line x1="2" y1="14" x2="50" y2="14" stroke-width="1.9"/>
            <line x1="2" y1="19" x2="50" y2="19" stroke-width="2.2"/>
            <line x1="2" y1="26" x2="50" y2="26" stroke-width="3"/>
            <line x1="2" y1="33" x2="50" y2="33" stroke-width="2.2"/>
            <line x1="2" y1="38" x2="50" y2="38" stroke-width="1.9"/>
            <line x1="2" y1="43" x2="50" y2="43" stroke-width="1.6"/>
            <line x1="26" y1="2" x2="26" y2="50" stroke-width="2.3"/>
          </g>
          <text x="58" y="31" font-family="Arial Black, Arial, sans-serif" font-weight="900" font-size="23" fill="#009FDB">AT&amp;T</text>
        </svg>

        <div style="width: 1px; height: 42px; background: var(--color-border);"></div>

        <!-- T-Mobile -->
        <svg width="160" height="52" viewBox="0 0 160 52" fill="none" aria-label="T-Mobile">
          <rect x="0" y="4" width="44" height="44" rx="5" fill="#E20074"/>
          <rect x="6" y="12" width="32" height="10" rx="2" fill="white"/>
          <rect x="19" y="12" width="10" height="28" rx="2" fill="white"/>
          <text x="52" y="31" font-family="Arial, Helvetica, sans-serif" font-weight="700" font-size="20" fill="#E20074">T-Mobile</text>
        </svg>

        <div style="width: 1px; height: 42px; background: var(--color-border);"></div>

        <!-- Google Fi -->
        <svg width="110" height="60" viewBox="0 0 110 60" fill="none" aria-label="Google Fi">
          <!-- 4-color arcs from bottom, clipped to avoid overflow -->
          <path d="M5 57 Q5 5 26 5 Q47 5 47 57"    fill="none" stroke="#4285F4" stroke-width="6" stroke-linecap="round"/>
          <path d="M12 57 Q12 13 26 13 Q40 13 40 57" fill="none" stroke="#EA4335" stroke-width="6" stroke-linecap="round"/>
          <path d="M19 57 Q19 21 26 21 Q33 21 33 57" fill="none" stroke="#FBBC05" stroke-width="6" stroke-linecap="round"/>
          <path d="M26 57 Q26 29 26 29 Q26 29 26 57"  fill="none" stroke="#34A853" stroke-width="6" stroke-linecap="round"/>
          <text x="56" y="26" font-family="Arial, sans-serif" font-weight="400" font-size="13" fill="rgba(255,255,255,0.75)">Google</text>
          <text x="56" y="50" font-family="Arial, Helvetica, sans-serif" font-weight="700" font-size="25" fill="white">Fi</text>
        </svg>

      </div>
    </div>
  </div>
</section>

<style>
  .hero-pulse {
    animation: hero-pulse-expand 3s ease-out infinite;
  }
  .hero-pulse.hp1 { transform-origin: 240px 188px; }
  .hero-pulse.hp2 { transform-origin: 240px 188px; animation-delay: 1s; }
  .hero-pulse.hp3 { transform-origin: 240px 188px; animation-delay: 2s; }

  @keyframes hero-pulse-expand {
    0%   { r: 38; opacity: 0.5; }
    100% { r: 84; opacity: 0; }
  }

  @keyframes hero-ping {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(1.5); }
  }
  .hero-ping { animation: hero-ping 1.5s ease-in-out infinite; }
</style>

<script>
  const heroRev = document.getElementById('hero-rev');
  let hVal = 0;
  const hTarget = 47.82;
  const hInc = hTarget / (8000 / 50);
  function tickHero(): void {
    hVal += hInc;
    if (hVal >= hTarget) hVal = 0;
    if (heroRev) heroRev.textContent = '$' + hVal.toFixed(2);
  }
  setInterval(tickHero, 50);
</script>
