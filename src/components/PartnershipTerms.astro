---
const terms = [
  {
    title: "Six-Month Trial Window",
    description: "Partner locations can cancel anytime during the first six months, no questions asked. During that window, the program stays month to month.",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>`,
  },
  {
    title: "No-Questions Cancellation",
    description: "If the program is not a fit, you have six months to exit with no long-term contract and no cancellation penalty.",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>`,
  },
  {
    title: "Annual Agreement After Month Six",
    description: "If you choose to continue after the first six months, the program automatically rolls into a one-year agreement.",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>`,
  },
  {
    title: "Automatic Annual Renewal",
    description: "After the first year, the agreement renews annually unless updated during the renewal window.",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.73"/></svg>`,
  },
  {
    title: "Carrier Reliability Requirement",
    description: "The annual term is requested by the major carriers so the offload network stays reliable once a location proves it is working.",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>`,
  },
  {
    title: "Transparent Reports",
    description: "Monthly revenue reports delivered by the 5th of each month. Full data visibility: sessions, GB offloaded, carrier breakdown.",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`,
  },
];
---
<section id="terms" class="py-28" style="background: var(--color-bg-surface);">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid lg:grid-cols-2 gap-16 items-center">

      <!-- Left: Header + quote -->
      <div>
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full mb-6 text-xs font-semibold tracking-widest uppercase"
             style="background: var(--color-primary-muted); color: var(--color-accent); font-family: var(--font-body); border: 1px solid rgba(27,111,235,0.2);">
          Partnership Terms
        </div>
        <h2 class="text-4xl lg:text-5xl font-bold mb-6" style="font-family: var(--font-display); letter-spacing: -0.02em;">
          Six Months to Decide.<br/>
          <span class="gradient-text">Carrier-Grade Reliability After.</span>
        </h2>
        <p class="text-lg mb-10" style="color: var(--color-text-secondary); font-family: var(--font-body); line-height: 1.7;">
          Partner locations can cancel anytime during the first six months, no questions asked. If the program is profitable and you choose to stay, it automatically rolls into a one-year agreement that renews annually. That reliability requirement comes from the major carriers, not from Mobile Offload.
        </p>

        <!-- Quote -->
        <blockquote class="p-6 rounded-2xl" style="background: var(--color-bg-card); border-left: 3px solid var(--color-primary);">
          <p class="text-sm leading-relaxed mb-4" style="color: var(--color-text-secondary); font-family: var(--font-body); font-style: italic;">
            "A plethora of trends will act to spur investments into Wi-Fi offloading in 2026. For mobile carriers, the challenge of grappling with ever-increasing traffic on their cellular networks... will drive them to expand their Wi-Fi offloading capabilities."
          </p>
          <footer class="text-sm font-semibold" style="color: var(--color-text-muted); font-family: var(--font-display);">
            — Wireless Broadband Alliance
          </footer>
        </blockquote>

        <!-- Simple revenue note -->
        <div class="mt-8 p-5 rounded-xl" style="background: var(--color-bg-elevated); border: 1px solid var(--color-border-bright);">
          <div class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0" style="background: rgba(16,185,129,0.12);">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#10B981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6L9 17l-5-5"/></svg>
            </div>
            <p class="text-sm" style="color: var(--color-text-secondary); font-family: var(--font-body); line-height: 1.6;">
              Revenue is shared with our partners on a straightforward basis — no fine print, no tiered structures, and no surprises. Details covered in your consultation.
            </p>
          </div>
        </div>
      </div>

      <!-- Right: Terms grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {terms.map((t) => (
          <div class="card-dark p-5 group cursor-default">
            <div class="w-10 h-10 rounded-xl flex items-center justify-center mb-4 transition-colors duration-200"
                 style="background: var(--color-primary-muted); color: var(--color-primary); border: 1px solid rgba(27,111,235,0.2);">
              <Fragment set:html={t.icon} />
            </div>
            <h3 class="text-base font-bold mb-2" style="font-family: var(--font-display);">{t.title}</h3>
            <p class="text-sm leading-relaxed" style="color: var(--color-text-secondary); font-family: var(--font-body);">{t.description}</p>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>
