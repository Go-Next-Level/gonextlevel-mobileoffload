---
---
<footer style="background: var(--color-bg-surface); border-top: 1px solid var(--color-border);">
  <div class="max-w-7xl mx-auto px-6 py-12">
    <div class="flex flex-col md:flex-row items-center justify-between gap-8">

      <!-- Logo + tagline -->
      <div class="text-center md:text-left">
        <a href="/" class="inline-flex items-center gap-2 mb-3 group" aria-label="Mobile Offload home">
          <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: linear-gradient(135deg, #1B6FEB, #0EA5E9);" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M5 12.55a11 11 0 0 1 14.08 0" stroke="white" stroke-width="2" stroke-linecap="round"/>
              <path d="M1.42 9a16 16 0 0 1 21.16 0" stroke="white" stroke-width="2" stroke-linecap="round"/>
              <path d="M8.53 16.11a6 6 0 0 1 6.95 0" stroke="white" stroke-width="2" stroke-linecap="round"/>
              <circle cx="12" cy="20" r="1" fill="white"/>
            </svg>
          </div>
          <span style="font-family: var(--font-display); font-weight: 700; font-size: 1.1rem; color: var(--color-text-primary);">
            Mobile<span style="color: var(--color-primary);">Offload</span>
          </span>
        </a>
        <p class="text-sm" style="color: var(--color-text-muted); font-family: var(--font-body);">WiFi that pays. © 2026 Mobile Offload. All rights reserved.</p>
      </div>

      <!-- Nav links -->
      <nav aria-label="Footer navigation">
        <div class="flex flex-wrap justify-center gap-6">
          <a href="#how-it-works" class="text-sm transition-colors duration-200 cursor-pointer" style="color: var(--color-text-muted); font-family: var(--font-body);"
             onmouseover="this.style.color='var(--color-text-primary)'" onmouseout="this.style.color='var(--color-text-muted)'">How It Works</a>
          <a href="#revenue" class="text-sm transition-colors duration-200 cursor-pointer" style="color: var(--color-text-muted); font-family: var(--font-body);"
             onmouseover="this.style.color='var(--color-text-primary)'" onmouseout="this.style.color='var(--color-text-muted)'">Revenue</a>
          <a href="#case-studies" class="text-sm transition-colors duration-200 cursor-pointer" style="color: var(--color-text-muted); font-family: var(--font-body);"
             onmouseover="this.style.color='var(--color-text-primary)'" onmouseout="this.style.color='var(--color-text-muted)'">Case Studies</a>
          <a href="#security" class="text-sm transition-colors duration-200 cursor-pointer" style="color: var(--color-text-muted); font-family: var(--font-body);"
             onmouseover="this.style.color='var(--color-text-primary)'" onmouseout="this.style.color='var(--color-text-muted)'">Security</a>
          <a href="#qualify" class="text-sm transition-colors duration-200 cursor-pointer" style="color: var(--color-text-muted); font-family: var(--font-body);"
             onmouseover="this.style.color='var(--color-text-primary)'" onmouseout="this.style.color='var(--color-text-muted)'">Get Started</a>
        </div>
      </nav>

      <!-- Contact -->
      <div class="text-center md:text-right">
        <a href="mailto:david@mobileoffload.com" class="text-sm block mb-1 transition-colors duration-200 cursor-pointer" style="color: var(--color-text-muted); font-family: var(--font-body);"
           onmouseover="this.style.color='var(--color-text-primary)'" onmouseout="this.style.color='var(--color-text-muted)'">david@mobileoffload.com</a>
        <a href="tel:3234479494" class="text-sm block transition-colors duration-200 cursor-pointer" style="color: var(--color-text-muted); font-family: var(--font-body);"
           onmouseover="this.style.color='var(--color-text-primary)'" onmouseout="this.style.color='var(--color-text-muted)'">323-447-9494</a>
      </div>

    </div>
  </div>
</footer>
