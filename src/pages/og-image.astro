---
// Dedicated OG image page — rendered headlessly at 1200×630
// Not linked in the site nav; only used for screenshot generation
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=1200" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;600;700&family=DM+Sans:wght@400;500&family=JetBrains+Mono:wght@500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      width: 1200px;
      height: 630px;
      overflow: hidden;
      background: #04070F;
      font-family: 'DM Sans', system-ui, sans-serif;
      -webkit-font-smoothing: antialiased;
      display: flex;
      flex-direction: column;
    }

    /* Background grid */
    .bg-grid {
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(rgba(27,111,235,0.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(27,111,235,0.04) 1px, transparent 1px);
      background-size: 40px 40px;
      pointer-events: none;
    }

    /* Ambient glow */
    .bg-glow {
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse 55% 70% at 70% 50%, rgba(27,111,235,0.09) 0%, transparent 70%),
                  radial-gradient(ellipse 30% 50% at 20% 30%, rgba(14,165,233,0.06) 0%, transparent 60%);
      pointer-events: none;
    }

    .container {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: 1fr 460px;
      align-items: center;
      height: 100%;
      padding: 44px 56px 44px 64px;
      gap: 40px;
    }

    /* LEFT SIDE */
    .left { display: flex; flex-direction: column; gap: 0; }

    .badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 6px 14px;
      border-radius: 999px;
      background: rgba(27,111,235,0.12);
      border: 1px solid rgba(27,111,235,0.25);
      color: #0EA5E9;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      font-family: 'DM Sans', sans-serif;
      margin-bottom: 22px;
      width: fit-content;
    }
    .badge-dot {
      width: 6px; height: 6px;
      border-radius: 50%;
      background: #0EA5E9;
      box-shadow: 0 0 6px rgba(14,165,233,0.8);
    }

    h1 {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 48px;
      font-weight: 700;
      line-height: 1.1;
      letter-spacing: -0.02em;
      color: #EDF2FF;
      margin-bottom: 16px;
    }
    h1 span {
      background: linear-gradient(135deg, #1B6FEB 0%, #0EA5E9 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .sub {
      font-size: 15px;
      line-height: 1.6;
      color: #7D99BE;
      max-width: 420px;
      margin-bottom: 28px;
    }

    .stats {
      display: flex;
      gap: 0;
    }
    .stat {
      padding-right: 28px;
      margin-right: 28px;
      border-right: 1px solid #1E3358;
    }
    .stat:last-child { border-right: none; margin-right: 0; padding-right: 0; }
    .stat-value {
      font-family: 'JetBrains Mono', monospace;
      font-size: 22px;
      font-weight: 600;
      color: #10B981;
      display: block;
      line-height: 1;
      margin-bottom: 4px;
    }
    .stat-value.blue { color: #0EA5E9; }
    .stat-value.white { color: #EDF2FF; }
    .stat-label {
      font-size: 11px;
      color: #4A6480;
      font-family: 'DM Sans', sans-serif;
    }

    /* BRANDING — inline in left col */
    .brand {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 20px;
    }
    .brand-logo {
      width: 32px; height: 32px;
      border-radius: 9px;
      background: linear-gradient(135deg, #1B6FEB 0%, #0EA5E9 100%);
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .brand-name {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 17px;
      font-weight: 700;
      color: #EDF2FF;
    }
    .brand-name span { color: #0EA5E9; }
    .brand-url {
      font-size: 12px;
      color: #4A6480;
      font-family: 'DM Sans', sans-serif;
      margin-left: 2px;
    }

    /* RIGHT SIDE — Network diagram */
    .right {
      position: relative;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .network-card {
      width: 440px;
      height: 440px;
      border-radius: 20px;
      background: linear-gradient(145deg, #0B1422 0%, #0D1B30 100%);
      border: 1px solid #1E3358;
      position: relative;
      overflow: hidden;
      box-shadow: 0 8px 48px rgba(0,0,0,0.5), 0 0 0 1px rgba(27,111,235,0.1);
    }

    .network-label {
      position: absolute;
      top: 18px;
      left: 50%;
      transform: translateX(-50%);
      font-size: 9px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: #4A6480;
      font-family: 'DM Sans', sans-serif;
      white-space: nowrap;
    }

    .live-badge {
      position: absolute;
      top: 14px;
      left: 16px;
      display: flex;
      align-items: center;
      gap: 5px;
      padding: 4px 10px;
      border-radius: 999px;
      background: rgba(16,185,129,0.15);
      border: 1px solid rgba(16,185,129,0.3);
      font-size: 10px;
      font-weight: 600;
      color: #10B981;
      font-family: 'DM Sans', sans-serif;
    }
    .live-dot {
      width: 5px; height: 5px;
      border-radius: 50%;
      background: #10B981;
      box-shadow: 0 0 4px rgba(16,185,129,0.8);
    }

    /* Carrier nodes */
    .carrier {
      position: absolute;
      width: 76px; height: 76px;
      border-radius: 50%;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      font-family: 'Space Grotesk', sans-serif;
      font-size: 12px;
      font-weight: 700;
      color: #EDF2FF;
    }
    .carrier-sub { font-size: 9px; font-weight: 400; color: #4A6480; font-family: 'DM Sans', sans-serif; margin-top: 2px; }

    .att {
      top: 68px; left: 46px;
      background: rgba(14,165,233,0.12);
      border: 2px solid rgba(14,165,233,0.5);
      box-shadow: 0 0 20px rgba(14,165,233,0.15);
      color: #0EA5E9;
    }
    .tmobile {
      top: 68px; left: 50%; transform: translateX(-50%);
      background: rgba(234,0,119,0.12);
      border: 2px solid rgba(234,0,119,0.5);
      box-shadow: 0 0 20px rgba(234,0,119,0.15);
      color: #EA0077;
    }
    .googlefi {
      top: 68px; right: 46px;
      background: rgba(27,111,235,0.12);
      border: 2px solid rgba(27,111,235,0.4);
      box-shadow: 0 0 20px rgba(27,111,235,0.15);
      color: #6EA4FF;
    }

    /* Your Location node */
    .location {
      position: absolute;
      bottom: 108px;
      left: 50%;
      transform: translateX(-50%);
      width: 96px; height: 96px;
      border-radius: 50%;
      background: rgba(27,111,235,0.15);
      border: 2px solid rgba(27,111,235,0.5);
      box-shadow: 0 0 32px rgba(27,111,235,0.25);
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      gap: 4px;
    }
    .location-icon { font-size: 22px; }
    .location-label { font-size: 8px; letter-spacing: 0.08em; text-transform: uppercase; color: #7D99BE; font-family: 'DM Sans', sans-serif; }

    /* Connection lines (SVG overlay) */
    .lines {
      position: absolute;
      inset: 0;
      width: 100%; height: 100%;
      pointer-events: none;
    }

    /* Revenue ticker */
    .revenue-ticker {
      position: absolute;
      bottom: 20px;
      left: 50%;
      transform: translateX(-50%);
      background: linear-gradient(135deg, #071A0F 0%, #081828 100%);
      border: 1px solid rgba(16,185,129,0.4);
      border-radius: 12px;
      padding: 10px 20px;
      text-align: center;
      min-width: 160px;
      box-shadow: 0 0 20px rgba(16,185,129,0.15);
    }
    .ticker-label { font-size: 9px; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(16,185,129,0.6); font-family: 'DM Sans', sans-serif; margin-bottom: 3px; }
    .ticker-value { font-family: 'JetBrains Mono', monospace; font-size: 22px; font-weight: 600; color: #10B981; }
  </style>
</head>
<body>
  <div class="bg-grid"></div>
  <div class="bg-glow"></div>

  <div class="container">
    <!-- LEFT -->
    <div class="left">
      <!-- Brand -->
      <div class="brand">
        <div class="brand-logo">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M1.5 8.5C5.5 4.5 10.5 2.5 12 2.5C13.5 2.5 18.5 4.5 22.5 8.5" stroke="white" stroke-width="2" stroke-linecap="round"/>
            <path d="M5 12C7.5 9.5 10 8 12 8C14 8 16.5 9.5 19 12" stroke="white" stroke-width="2" stroke-linecap="round"/>
            <circle cx="12" cy="17" r="2.5" fill="white"/>
          </svg>
        </div>
        <span class="brand-name">Mobile<span>Offload</span></span>
        <span class="brand-url">mobileoffload.com</span>
      </div>

      <div class="badge">
        <span class="badge-dot"></span>
        Carrier Offload Network Partnership
      </div>

      <h1>Get Paid When<br/><span>Mobile Data</span> Is Used<br/>at Your Location</h1>

      <p class="sub">AT&T, T-Mobile, and Google Fi pay you every time their subscribers come in range of your business — zero hardware, zero setup fees.</p>

      <div class="stats">
        <div class="stat">
          <span class="stat-value">Monthly</span>
          <span class="stat-label">Payouts Per GB</span>
        </div>
        <div class="stat">
          <span class="stat-value blue">124K+</span>
          <span class="stat-label">Active Subscribers</span>
        </div>
        <div class="stat">
          <span class="stat-value white">$0</span>
          <span class="stat-label">Upfront Cost</span>
        </div>
      </div>
    </div>

    <!-- RIGHT -->
    <div class="right">
      <div class="network-card">
        <div class="live-badge"><span class="live-dot"></span> Live</div>
        <div class="network-label">Carrier Network</div>

        <!-- SVG connection lines -->
        <svg class="lines" viewBox="0 0 440 440" xmlns="http://www.w3.org/2000/svg">
          <!-- AT&T to location -->
          <line x1="84" y1="144" x2="220" y2="296" stroke="rgba(14,165,233,0.35)" stroke-width="1.5" stroke-dasharray="4 4"/>
          <!-- T-Mobile to location -->
          <line x1="220" y1="144" x2="220" y2="296" stroke="rgba(234,0,119,0.35)" stroke-width="1.5" stroke-dasharray="4 4"/>
          <!-- Google Fi to location -->
          <line x1="356" y1="144" x2="220" y2="296" stroke="rgba(27,111,235,0.35)" stroke-width="1.5" stroke-dasharray="4 4"/>
          <!-- Location to revenue -->
          <line x1="220" y1="344" x2="220" y2="374" stroke="rgba(16,185,129,0.4)" stroke-width="1.5"/>
          <!-- Dot indicators on lines -->
          <circle cx="152" cy="220" r="3" fill="rgba(14,165,233,0.7)"/>
          <circle cx="220" cy="220" r="3" fill="rgba(234,0,119,0.7)"/>
          <circle cx="288" cy="220" r="3" fill="rgba(27,111,235,0.7)"/>
        </svg>

        <!-- Carriers -->
        <div class="carrier att">AT&T<span class="carrier-sub">Carrier</span></div>
        <div class="carrier tmobile">T-Mobile<span class="carrier-sub">Carrier</span></div>
        <div class="carrier googlefi">Google Fi<span class="carrier-sub">Carrier</span></div>

        <!-- Your Location -->
        <div class="location">
          <span class="location-icon">🏢</span>
          <span class="location-label">Your Location</span>
        </div>

        <!-- Revenue Ticker -->
        <div class="revenue-ticker">
          <div class="ticker-label">Revenue Earned</div>
          <div class="ticker-value">$46.92</div>
        </div>
      </div>
    </div>
  </div>

</body>
</html>
