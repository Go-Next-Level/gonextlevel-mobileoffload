---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import HowItWorks from '../components/HowItWorks.astro';
import NetworkAnimation from '../components/NetworkAnimation.astro';
import RevenueCalculator from '../components/RevenueCalculator.astro';
import CaseStudies from '../components/CaseStudies.astro';
import Security from '../components/Security.astro';
import PartnershipTerms from '../components/PartnershipTerms.astro';
import FAQ from '../components/FAQ.astro';
import QualifyForm from '../components/QualifyForm.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const title = "Mobile Offload — Turn Your Wi-Fi Into Passive Monthly Revenue";
const description = "Turn your existing Wi-Fi into passive monthly revenue through carrier offload. AT&T, T-Mobile, and Google Fi pay you every time their subscribers use your network. Zero hardware, zero upfront costs.";
---
<Base title={title} description={description}>
  <main id="main">
    <Nav />
    <Hero />
    <RevenueCalculator />
    <HowItWorks />
    <NetworkAnimation />
    <CaseStudies />
    <Security />
    <PartnershipTerms />
    <FAQ />
    <QualifyForm />
    <Footer />
  </main>
</Base>
