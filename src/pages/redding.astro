            Eligibility
          </div>
          <h2 class="text-4xl lg:text-5xl font-bold mb-6" style="font-family: var(--font-display); letter-spacing: -0.02em;">
            Who In Redding<br/>
            <span class="gradient-text-blue">May Qualify?</span>
          </h2>
          <p class="text-lg max-w-3xl mx-auto" style="color: var(--color-text-secondary); font-family: var(--font-body); line-height: 1.7;">
            The best fit is usually a location that already has regular daily visitors, longer dwell time, or repeat foot traffic. That can include a wide range of Redding businesses and properties.
          </p>
        </div>

        <!-- Location type grid -->
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4 mb-16">
          {locationTypes.map(loc => (
            <div class="card-dark card-lift p-5 flex items-center gap-4">
              <span style="font-size: 1.75rem;" aria-hidden="true">{loc.icon}</span>
              <span class="font-semibold text-sm" style="font-family: var(--font-display);">{loc.label}</span>
            </div>
          ))}
        </div>

        <!-- Eligibility callout -->
        <div class="grid lg:grid-cols-2 gap-6">
          <div class="p-8 rounded-2xl" style="background: linear-gradient(135deg, #0A1930 0%, #0D2040 100%); border: 1px solid rgba(27,111,235,0.3);">
            <div class="text-xs font-semibold tracking-widest uppercase mb-4" style="color: var(--color-accent); font-family: var(--font-body);">Good Fit Indicators</div>
            <ul class="flex flex-col gap-3">
              {[
                "Regular daily foot traffic (50+ visitors/day)",
                "Repeat visitors or longer dwell times",
                "Commercial or public-facing property",
                "Existing network infrastructure on-site",
                "Open to a 30-day month-to-month agreement",
              ].map(item => (
                <li class="flex items-start gap-3 text-sm" style="color: var(--color-text-secondary); font-family: var(--font-body);">
                  <svg class="flex-shrink-0 mt-0.5" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-success)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6L9 17l-5-5"/></svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>

          <div class="p-8 rounded-2xl" style="background: var(--color-bg-card); border: 1px solid var(--color-border-bright);">
            <div class="text-xs font-semibold tracking-widest uppercase mb-4" style="color: var(--color-text-muted); font-family: var(--font-body);">Not Sure If You Qualify?</div>
            <p class="text-sm mb-6" style="color: var(--color-text-secondary); font-family: var(--font-body); line-height: 1.7;">
              Not every property will qualify. Eligibility depends on location type, visitor volume, network demand, and carrier fit. The first step is simply to submit your location so we can review whether it may be a fit for the program.
            </p>
            <p class="text-sm mb-6" style="color: var(--color-text-secondary); font-family: var(--font-body); line-height: 1.7;">
              There's no commitment involved in submitting. We'll let you know if your Redding location looks like a potential match.
            </p>
            <a href="#qualify"
               class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-semibold text-white text-sm transition-all duration-200 cursor-pointer"
               style="background: var(--color-primary);"
               onmouseover="this.style.background='var(--color-primary-hover)'"
               onmouseout="this.style.background='var(--color-primary)'">
              Check My Location
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>

      </div>
    </section>

    <!-- ── CASE STUDIES (reused) ─────────────────────────────────── -->
    <CaseStudies />

    <!-- ── SECURITY (reused) ─────────────────────────────────────── -->
    <Security />

    <!-- ── PARTNERSHIP TERMS (reused) ───────────────────────────── -->
    <PartnershipTerms />

    <!-- ── REDDING FAQ ───────────────────────────────────────────── -->
    <section id="faq" class="py-28" style="background: var(--color-bg-base);">
      <div class="max-w-3xl mx-auto px-6">

        <div class="text-center mb-16">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full mb-6 text-xs font-semibold tracking-widest uppercase"
               style="background: var(--color-primary-muted); color: var(--color-accent); font-family: var(--font-body); border: 1px solid rgba(27,111,235,0.2);">
            FAQ
          </div>
          <h2 class="text-3xl lg:text-4xl font-bold" style="font-family: var(--font-display); letter-spacing: -0.02em;">
            Common Questions<br/>
            <span class="gradient-text-blue">From Redding Business Owners</span>
          </h2>
        </div>

        <div class="flex flex-col gap-2" id="redding-faq-list">
          {reddingFaqs.map((faq, i) => (
            <div class="faq-item rounded-xl overflow-hidden" style="background: var(--color-bg-surface); border: 1px solid var(--color-border);">
              <button
                type="button"
                class="faq-trigger w-full flex items-center justify-between gap-4 px-6 py-5 text-left cursor-pointer transition-colors duration-150"
                aria-expanded="false"
                aria-controls={`rfaq-answer-${i}`}
                id={`rfaq-trigger-${i}`}
              >
                <span class="text-base font-semibold" style="font-family: var(--font-display);">{faq.q}</span>
                <svg class="faq-chevron flex-shrink-0 transition-transform duration-200" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M6 9l6 6 6-6"/>
                </svg>
              </button>
              <div
                id={`rfaq-answer-${i}`}
                role="region"
                aria-labelledby={`rfaq-trigger-${i}`}
                class="faq-answer overflow-hidden"
                style="max-height: 0; transition: max-height 0.25s ease;"
              >
                <p class="px-6 pb-5 text-sm leading-relaxed" style="color: var(--color-text-secondary); font-family: var(--font-body);">{faq.a}</p>
              </div>
            </div>
          ))}
        </div>

      </div>
    </section>

    <!-- ── FINAL CTA ──────────────────────────────────────────────── -->
    <section class="py-20 relative overflow-hidden" style="background: var(--color-bg-surface);">
      <div class="absolute inset-0 pointer-events-none" aria-hidden="true"
           style="background: radial-gradient(ellipse 60% 80% at 50% 50%, rgba(27,111,235,0.07) 0%, transparent 70%);"></div>
      <div class="relative max-w-3xl mx-auto px-6 text-center">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full mb-8 text-xs font-semibold tracking-widest uppercase"
             style="background: var(--color-primary-muted); color: var(--color-accent); font-family: var(--font-body); border: 1px solid rgba(27,111,235,0.2);">
          Redding Business Owners
        </div>
        <h2 class="text-4xl lg:text-5xl font-bold mb-6" style="font-family: var(--font-display); letter-spacing: -0.02em;">
          See If Your Location<br/>
          <span class="gradient-text-blue">Qualifies</span>
        </h2>
        <p class="text-lg mb-10 max-w-2xl mx-auto" style="color: var(--color-text-secondary); font-family: var(--font-body); line-height: 1.7;">
          If your property gets regular foot traffic, it may be worth reviewing. Submit your location and we'll help determine whether it could be a fit for Mobile Offload.
        </p>
        <a href="#qualify"
           class="inline-flex items-center gap-2 px-8 py-4 rounded-xl text-base font-semibold text-white transition-all duration-200 cursor-pointer"
           style="background: var(--color-primary);"
           onmouseover="this.style.background='var(--color-primary-hover)'; this.style.transform='translateY(-1px)'; this.style.boxShadow='0 8px 28px rgba(27,111,235,0.4)'"
           onmouseout="this.style.background='var(--color-primary)'; this.style.transform=''; this.style.boxShadow=''">
          Check If My Location Qualifies
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </section>

    <!-- ── QUALIFY FORM (reused) ─────────────────────────────────── -->
    <QualifyForm />

    <Footer />
  </main>
</Base>

<style>
  .faq-trigger:hover {
    background: var(--color-bg-elevated);
  }
  .faq-item.open .faq-chevron {
    transform: rotate(180deg);
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('#redding-faq-list .faq-trigger').forEach(trigger => {
    trigger.addEventListener('click', () => {
      const item = trigger.closest('.faq-item') as HTMLElement;
      const answer = trigger.nextElementSibling as HTMLElement;
      const isOpen = item.classList.contains('open');

      // Close all in this list
      document.querySelectorAll<HTMLElement>('#redding-faq-list .faq-item').forEach(el => {
        el.classList.remove('open');
        const ans = el.querySelector<HTMLElement>('.faq-answer');
        const btn = el.querySelector<HTMLButtonElement>('.faq-trigger');
        if (ans) ans.style.maxHeight = '0';
        if (btn) btn.setAttribute('aria-expanded', 'false');
      });

      if (!isOpen) {
        item.classList.add('open');
        answer.style.maxHeight = answer.scrollHeight + 'px';
        trigger.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>
