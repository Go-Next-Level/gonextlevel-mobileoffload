---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import RevenueCalculator from '../components/RevenueCalculator.astro';
import HowItWorks from '../components/HowItWorks.astro';
import CaseStudies from '../components/CaseStudies.astro';
import Security from '../components/Security.astro';
import PartnershipTerms from '../components/PartnershipTerms.astro';
import QualifyForm from '../components/QualifyForm.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const title = "Redding Mobile Offload Program | Earn Monthly Income From Foot Traffic";
const description = "Redding business and property owners may qualify for monthly carrier program income through Mobile Offload. No hardware purchase, no equipment investment, and no disruption to your business.";

const locationTypes = [
  { icon: "☕", label: "Coffee Shops" },
  { icon: "🍽️", label: "Restaurants" },
  { icon: "💪", label: "Gyms & Fitness Centers" },
  { icon: "⛪", label: "Churches" },
  { icon: "🏨", label: "Hotels & Motels" },
  { icon: "🏥", label: "Medical Offices" },
  { icon: "🛍️", label: "Retail Stores" },
  { icon: "🏬", label: "Shopping Centers" },
  { icon: "⛽", label: "Gas Stations" },
  { icon: "🎪", label: "Event Venues" },
  { icon: "🏛️", label: "Campuses & Large Facilities" },
  { icon: "🏢", label: "Commercial Properties" },
];

const reddingFaqs = [
  {
    q: "Is this only for Redding businesses?",
    a: "No. Mobile Offload is a nationwide program already active across the country. This page is specifically for business and property owners in Redding, California who want a local point of contact to review whether their location may qualify.",
  },
  {
    q: "Do I need to buy any equipment?",
    a: "No. Qualified locations do not need to purchase new hardware or equipment to participate in the program.",
  },
  {
    q: "Will this disrupt my business or my customers?",
    a: "No. The program is designed from the ground up to avoid disrupting your customers, staff, or day-to-day operations. The carrier offload runs on a completely separate, isolated channel.",
  },
  {
    q: "What types of Redding locations are a good fit?",
    a: "Locations with steady foot traffic are usually the best fit. Examples include coffee shops, restaurants, gyms, churches, hotels, retail stores, medical offices, gas stations, and shopping centers. If people regularly visit your property, it may be worth reviewing.",
  },
  {
    q: "How much can my Redding location earn?",
    a: "Earnings depend on location type, foot traffic volume, carrier demand in your area, and qualification status. The interactive calculator on this page uses real deployment data to estimate potential monthly income based on your venue type.",
  },
  {
    q: "How does the revenue share work?",
    a: "Carrier revenue is split equally between Mobile Offload and the location partner — you receive 50% of all carrier payments generated by your location. There are no tiered structures, no sliding scales, and no fine print. Your share is paid by the 5th of each month with a full breakdown report.",
  },
  {
    q: "Does this affect my existing internet or Wi-Fi?",
    a: "No. The carrier offload network runs on a completely separate SSID with dedicated bandwidth allocation. Your guest network, internal network, and POS systems are entirely untouched.",
  },
  {
    q: "What carriers are supported?",
    a: "We currently support AT&T, T-Mobile, and Google Fi. Their subscribers connect automatically — no login screen or password required on their end.",
  },
  {
    q: "How long does setup take?",
    a: "Approximately 1 hour. We work with your IT team or network administrator to configure a dedicated SSID and run connectivity tests. Setup is scheduled during off-peak hours to minimize any disruption.",
  },
  {
    q: "What if I want to stop?",
    a: "Either party can exit with 30 days written notice. There are no termination fees, no penalties, and no minimum revenue requirements. On exit, we restore your network to its original configuration.",
  },
];
---

<Base title={title} description={description}>
  <main id="main">
    <Nav />

    <!-- ── HERO ─────────────────────────────────────────────────── -->
    <section class="relative overflow-hidden grid-texture" style="background: var(--color-bg-base); min-height: 90vh; display: flex; align-items: center;">
      <!-- Background glow -->
      <div class="absolute inset-0 pointer-events-none" aria-hidden="true"
           style="background: radial-gradient(ellipse 60% 50% at 70% 50%, rgba(27,111,235,0.08) 0%, transparent 70%), radial-gradient(ellipse 40% 60% at 10% 80%, rgba(14,165,233,0.05) 0%, transparent 60%);"></div>

      <div class="relative max-w-7xl mx-auto px-6 py-24 w-full">
        <div class="grid lg:grid-cols-2 gap-16 items-center">

          <!-- Left: Copy -->
          <div>
            <!-- Local badge -->
            <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full mb-8 text-sm font-medium"
                 style="background: rgba(14,165,233,0.1); border: 1px solid rgba(14,165,233,0.2); color: var(--color-accent); font-family: var(--font-body);">
              <span style="width:8px;height:8px;border-radius:50%;background:var(--color-accent);display:inline-block;box-shadow:0 0 6px rgba(14,165,233,0.8);" aria-hidden="true"></span>
              Redding, California · Local Program Access
            </div>

            <h1 class="font-bold mb-6 leading-tight" style="font-family: var(--font-display); font-size: clamp(2rem, 4vw, 3.25rem); letter-spacing: -0.02em;">
              Redding Businesses With<br/>
              <span class="gradient-text-blue">Foot Traffic May Qualify</span><br/>
              For Monthly Carrier<br/>Program Income
            </h1>

            <p class="text-lg mb-10 max-w-xl" style="color: var(--color-text-secondary); font-family: var(--font-body); line-height: 1.7;">
              If your Redding location gets steady visitors, your property may be valuable to major mobile carriers looking to reduce network congestion. Mobile Offload helps qualified locations earn monthly income without new hardware, equipment purchases, or changes to daily operations.
            </p>

            <div class="flex flex-col sm:flex-row gap-4 mb-14">
              <a href="#qualify"
                 class="inline-flex items-center justify-center gap-2 px-7 py-4 rounded-xl text-base font-semibold text-white transition-all duration-200 cursor-pointer"
                 style="background: var(--color-primary);"
                 onmouseover="this.style.background='var(--color-primary-hover)'; this.style.transform='translateY(-1px)'; this.style.boxShadow='0 8px 28px rgba(27,111,235,0.4)'"
                 onmouseout="this.style.background='var(--color-primary)'; this.style.transform=''; this.style.boxShadow=''">
                Check If My Redding Location Qualifies
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
              <a href="#how-it-works"
                 class="inline-flex items-center justify-center gap-2 px-7 py-4 rounded-xl text-base font-medium transition-all duration-200 cursor-pointer"
                 style="background: var(--color-bg-card); border: 1px solid var(--color-border-bright); color: var(--color-text-secondary);"
                 onmouseover="this.style.borderColor='var(--color-primary)'; this.style.color='var(--color-text-primary)'"
                 onmouseout="this.style.borderColor='var(--color-border-bright)'; this.style.color='var(--color-text-secondary)'">
                See How It Works
              </a>
            </div>

            <!-- Stats row -->
            <div class="flex flex-wrap gap-0">
              <div class="pr-8 mr-8" style="border-right: 1px solid var(--color-border-bright);">
                <div class="text-2xl font-bold mb-1" style="font-family: var(--font-mono); color: var(--color-success);">Monthly Payouts</div>
                <div class="text-sm" style="color: var(--color-text-muted); font-family: var(--font-body);">Per GB of data offloaded</div>
              </div>
              <div class="pr-8 mr-8" style="border-right: 1px solid var(--color-border-bright);">
                <div class="text-2xl font-bold mb-1" style="font-family: var(--font-mono); color: var(--color-accent);">124K+</div>
                <div class="text-sm" style="color: var(--color-text-muted); font-family: var(--font-body);">Active Subscribers</div>
              </div>
              <div>
                <div class="text-2xl font-bold mb-1" style="font-family: var(--font-mono); color: var(--color-text-primary);">$0</div>
                <div class="text-sm" style="color: var(--color-text-muted); font-family: var(--font-body);">Upfront Cost</div>
              </div>
            </div>
          </div>

          <!-- Right: Visual card -->
          <div class="hidden lg:flex items-center justify-center">
            <div class="relative w-full max-w-md">
              <!-- Main card -->
              <div class="p-8 rounded-2xl" style="background: var(--color-bg-card); border: 1px solid var(--color-border-bright); box-shadow: 0 16px 64px rgba(0,0,0,0.4);">
                <div class="text-xs font-semibold tracking-widest uppercase mb-6" style="color: var(--color-text-muted); font-family: var(--font-body);">Redding, CA · Local Coverage Active</div>

                <!-- Location types preview -->
                <div class="grid grid-cols-3 gap-3 mb-8">
                  {["☕ Coffee", "🍽️ Dining", "💪 Gym", "⛪ Church", "🏨 Hotel", "🏥 Medical"].map(item => (
                    <div class="flex flex-col items-center gap-1.5 p-3 rounded-xl text-center" style="background: var(--color-bg-elevated); border: 1px solid var(--color-border);">
                      <span style="font-size: 1.25rem;">{item.split(' ')[0]}</span>
                      <span class="text-xs" style="color: var(--color-text-muted); font-family: var(--font-body);">{item.split(' ').slice(1).join(' ')}</span>
                    </div>
                  ))}
                </div>

                <div class="section-divider mb-6"></div>

                <!-- Revenue preview -->
                <div class="flex items-center justify-between mb-3">
                  <span class="text-sm" style="color: var(--color-text-muted); font-family: var(--font-body);">Estimated Monthly Range</span>
                  <span class="text-xs px-2 py-1 rounded-full" style="background: rgba(16,185,129,0.12); color: var(--color-success); font-family: var(--font-body);">Based on real data</span>
                </div>
                <div class="text-3xl font-bold mb-1" style="font-family: var(--font-mono); color: var(--color-success);">$500 – $9,600+</div>
                <div class="text-xs" style="color: var(--color-text-muted); font-family: var(--font-body);">Varies by location type and foot traffic</div>

                <a href="#qualify"
                   class="mt-6 flex items-center justify-center gap-2 w-full py-3.5 rounded-xl font-semibold text-sm text-white transition-all duration-200 cursor-pointer"
                   style="background: var(--color-primary);"
                   onmouseover="this.style.background='var(--color-primary-hover)'"
                   onmouseout="this.style.background='var(--color-primary)'">
                  Check My Redding Location
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </a>
              </div>

              <!-- Floating badge -->
              <div class="absolute -top-4 -right-4 px-3 py-2 rounded-xl text-xs font-bold"
                   style="background: var(--color-bg-elevated); border: 1px solid rgba(16,185,129,0.4); color: var(--color-success); font-family: var(--font-body); box-shadow: 0 4px 16px rgba(0,0,0,0.3);">
                ✓ No Hardware Required
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ── VIDEO PLACEHOLDER ─────────────────────────────────────── -->
    <section class="py-24" style="background: var(--color-bg-surface);">
      <div class="max-w-4xl mx-auto px-6">

        <div class="text-center mb-10">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full mb-6 text-xs font-semibold tracking-widest uppercase"
               style="background: var(--color-primary-muted); color: var(--color-accent); font-family: var(--font-body); border: 1px solid rgba(27,111,235,0.2);">
            Program Overview
          </div>
          <h2 class="text-3xl lg:text-4xl font-bold mb-4" style="font-family: var(--font-display); letter-spacing: -0.02em;">
            See How Mobile Offload Works
          </h2>
          <p class="text-lg max-w-2xl mx-auto" style="color: var(--color-text-secondary); font-family: var(--font-body);">
            A short walkthrough for Redding business owners explaining how the program works and what types of locations may qualify.
          </p>
        </div>

        <!-- Video embed placeholder -->
        <div class="relative rounded-2xl overflow-hidden"
             style="background: var(--color-bg-card); border: 1px solid var(--color-border-bright); aspect-ratio: 16/9; box-shadow: 0 12px 48px rgba(0,0,0,0.35);">
          <!-- Grid texture overlay -->
          <div class="absolute inset-0" style="background-image: linear-gradient(rgba(27,111,235,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(27,111,235,0.03) 1px, transparent 1px); background-size: 40px 40px;" aria-hidden="true"></div>
          <!-- Glow -->
          <div class="absolute inset-0" style="background: radial-gradient(ellipse 50% 60% at 50% 50%, rgba(27,111,235,0.08) 0%, transparent 70%);" aria-hidden="true"></div>

          <div class="absolute inset-0 flex flex-col items-center justify-center gap-5">
            <!-- Play button -->
            <div class="w-20 h-20 rounded-full flex items-center justify-center"
                 style="background: rgba(27,111,235,0.15); border: 2px solid rgba(27,111,235,0.35);">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <polygon points="5,3 19,12 5,21" fill="var(--color-primary)" opacity="0.7"/>
              </svg>
            </div>

            <div class="text-center">
              <p class="text-xl font-bold mb-2" style="font-family: var(--font-display); color: var(--color-text-primary);">
                Video Explainer Coming Soon
              </p>
              <p class="text-sm max-w-sm mx-auto" style="color: var(--color-text-muted); font-family: var(--font-body); line-height: 1.6;">
                A short walkthrough for Redding business owners explaining how Mobile Offload works and what types of locations may qualify.
              </p>
            </div>

            <!-- Coming soon badge -->
            <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-xs font-semibold"
                 style="background: rgba(14,165,233,0.1); border: 1px solid rgba(14,165,233,0.2); color: var(--color-accent); font-family: var(--font-body);">
              <span style="width:6px;height:6px;border-radius:50%;background:var(--color-accent);display:inline-block;" aria-hidden="true"></span>
              In Production
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- ── FOOT TRAFFIC VALUE PROP ────────────────────────────────── -->
    <section class="py-28 relative" style="background: var(--color-bg-base);">
      <div class="absolute left-0 top-1/2 -translate-y-1/2 w-96 h-96 rounded-full opacity-5 pointer-events-none" aria-hidden="true"
           style="background: radial-gradient(circle, #0EA5E9, transparent); filter: blur(80px);"></div>
      <div class="max-w-7xl mx-auto px-6">

        <div class="grid lg:grid-cols-2 gap-16 items-center">
          <div>
            <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full mb-6 text-xs font-semibold tracking-widest uppercase"
                 style="background: rgba(14,165,233,0.1); color: var(--color-accent); font-family: var(--font-body); border: 1px solid rgba(14,165,233,0.2);">
              The Opportunity
            </div>
            <h2 class="text-4xl lg:text-5xl font-bold mb-6" style="font-family: var(--font-display); letter-spacing: -0.02em;">
              Redding Foot Traffic<br/>
              <span class="gradient-text-blue">May Be More Valuable</span><br/>
              Than You Think
            </h2>
            <p class="text-lg mb-6" style="color: var(--color-text-secondary); font-family: var(--font-body); line-height: 1.7;">
              Every day, thousands of people move through Redding businesses, churches, hotels, gyms, restaurants, and retail locations using mobile data. Major carriers are actively looking for ways to reduce pressure on their networks in areas with consistent traffic.
            </p>
            <p class="text-lg mb-8" style="color: var(--color-text-secondary); font-family: var(--font-body); line-height: 1.7;">
              Mobile Offload connects qualified properties with carrier-backed offload opportunities so participating locations can potentially earn monthly income from the traffic they already have — with no new hardware, no equipment purchases, and no disruption to daily operations.
            </p>
            <a href="#qualify"
               class="inline-flex items-center gap-2 px-6 py-3.5 rounded-xl font-semibold text-white text-sm transition-all duration-200 cursor-pointer"
               style="background: var(--color-primary);"
               onmouseover="this.style.background='var(--color-primary-hover)'"
               onmouseout="this.style.background='var(--color-primary)'">
              See If My Location Qualifies
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>

          <!-- Right: 3 value cards -->
          <div class="flex flex-col gap-5">
            <div class="card-dark p-6 flex items-start gap-5">
              <div class="w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0" style="background: rgba(16,185,129,0.12); border: 1px solid rgba(16,185,129,0.25);">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--color-success)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
              </div>
              <div>
                <h3 class="font-bold mb-2" style="font-family: var(--font-display);">New Monthly Income Stream</h3>
                <p class="text-sm" style="color: var(--color-text-secondary); font-family: var(--font-body); line-height: 1.6;">Qualified locations earn monthly income generated by carrier subscribers already visiting your property — no sales, no marketing, no effort on your end.</p>
              </div>
            </div>

            <div class="card-dark p-6 flex items-start gap-5">
              <div class="w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0" style="background: var(--color-primary-muted); border: 1px solid rgba(27,111,235,0.25);">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </div>
              <div>
                <h3 class="font-bold mb-2" style="font-family: var(--font-display);">Zero Risk to Your Network</h3>
                <p class="text-sm" style="color: var(--color-text-secondary); font-family: var(--font-body); line-height: 1.6;">The carrier offload operates on a completely separate, isolated channel. Your internal systems, guest Wi-Fi, POS, and operations are never touched.</p>
              </div>
            </div>

            <div class="card-dark p-6 flex items-start gap-5">
              <div class="w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0" style="background: rgba(14,165,233,0.1); border: 1px solid rgba(14,165,233,0.2);">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              </div>
              <div>
                <h3 class="font-bold mb-2" style="font-family: var(--font-display);">Paid the 5th of Every Month</h3>
                <p class="text-sm" style="color: var(--color-text-secondary); font-family: var(--font-body); line-height: 1.6;">Revenue is paid monthly with a full breakdown report showing sessions, GB offloaded, and carrier contributions. No guesswork, no chasing payments.</p>
              </div>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- ── NO HARDWARE SECTION ────────────────────────────────────── -->
    <section class="py-28" style="background: var(--color-bg-surface);">
      <div class="max-w-7xl mx-auto px-6">

        <div class="text-center mb-16">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full mb-6 text-xs font-semibold tracking-widest uppercase"
               style="background: rgba(16,185,129,0.1); color: var(--color-success); font-family: var(--font-body); border: 1px solid rgba(16,185,129,0.2);">
            How It's Different
          </div>
          <h2 class="text-4xl lg:text-5xl font-bold mb-6" style="font-family: var(--font-display); letter-spacing: -0.02em;">
            No New Hardware.<br/>
            <span class="gradient-text-blue">No Equipment Purchase.</span><br/>
            No Operational Disruption.
          </h2>
          <p class="text-lg max-w-3xl mx-auto" style="color: var(--color-text-secondary); font-family: var(--font-body); line-height: 1.7;">
            For qualified locations, the program is designed to work without requiring a business to buy new equipment, install additional hardware, or change the way they serve customers. The goal is simple: help eligible high-traffic properties turn existing visitor activity into a new monthly income opportunity.
          </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
          {[
            { icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>`, title: "No New Hardware", body: "We use your existing access points and infrastructure exactly as-is in most cases." },
            { icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>`, title: "No Equipment Cost", body: "Qualified locations do not need to purchase, lease, or finance any new equipment to participate." },
            { icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`, title: "No Customer Disruption", body: "Carrier subscribers connect automatically in the background. Your customers and staff never notice a change." },
            { icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`, title: "~1 Hour Setup", body: "Software configuration only. Scheduled during off-peak hours so your business is never interrupted." },
          ].map(item => (
            <div class="card-dark p-6">
              <div class="w-11 h-11 rounded-xl flex items-center justify-center mb-5"
                   style="background: rgba(16,185,129,0.1); border: 1px solid rgba(16,185,129,0.2); color: var(--color-success);">
                <Fragment set:html={item.icon} />
              </div>
              <h3 class="font-bold mb-2" style="font-family: var(--font-display);">{item.title}</h3>
              <p class="text-sm" style="color: var(--color-text-secondary); font-family: var(--font-body); line-height: 1.6;">{item.body}</p>
            </div>
          ))}
        </div>

      </div>
    </section>

    <!-- ── REVENUE CALCULATOR (reused) ───────────────────────────── -->
    <RevenueCalculator />

    <!-- ── HOW IT WORKS (reused) ─────────────────────────────────── -->
    <HowItWorks />

    <!-- ── WHO QUALIFIES ─────────────────────────────────────────── -->
    <section class="py-28 relative" style="background: var(--color-bg-base);">
      <div class="max-w-7xl mx-auto px-6">

