---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import RevenueCalculator from '../components/RevenueCalculator.astro';
import HowItWorks from '../components/HowItWorks.astro';
import CaseStudies from '../components/CaseStudies.astro';
import Security from '../components/Security.astro';
import PartnershipTerms from '../components/PartnershipTerms.astro';
import QualifyForm from '../components/QualifyForm.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const title = "Redding Mobile Offload Program | Earn Monthly Income From Foot Traffic";
const description = "Redding business and property owners may qualify for monthly carrier program income through Mobile Offload. No hardware purchase, no equipment investment, and no disruption to your business.";

const locationTypes = [
  { icon: "☕", label: "Coffee Shops" },
  { icon: "🍽️", label: "Restaurants" },
  { icon: "💪", label: "Gyms & Fitness Centers" },
  { icon: "⛪", label: "Churches" },
  { icon: "🏨", label: "Hotels & Motels" },
  { icon: "🏥", label: "Medical Offices" },
  { icon: "🛍️", label: "Retail Stores" },
  { icon: "🏬", label: "Shopping Centers" },
  { icon: "⛽", label: "Gas Stations" },
  { icon: "🎪", label: "Event Venues" },
  { icon: "🏛️", label: "Campuses & Large Facilities" },
  { icon: "🏢", label: "Commercial Properties" },
];

const reddingFaqs = [
  {
    q: "Is this only for Redding businesses?",
    a: "No. Mobile Offload is a nationwide program already active across the country. This page is specifically for business and property owners in Redding, California who want a local point of contact to review whether their location may qualify.",
  },
  {
    q: "Do I need to buy any equipment?",
    a: "No. Qualified locations do not need to purchase new hardware or equipment to participate in the program.",
  },
  {
    q: "Will this disrupt my business or my customers?",
    a: "No. The program is designed from the ground up to avoid disrupting your customers, staff, or day-to-day operations. The carrier offload runs on a completely separate, isolated channel.",
  },
  {
    q: "What types of Redding locations are a good fit?",
    a: "Locations with steady foot traffic are usually the best fit. Examples include coffee shops, restaurants, gyms, churches, hotels, retail stores, medical offices, gas stations, and shopping centers. If people regularly visit your property, it may be worth reviewing.",
  },
  {
    q: "How much can my Redding location earn?",
    a: "Earnings depend on location type, foot traffic volume, carrier demand in your area, and qualification status. The interactive calculator on this page uses real deployment data to estimate potential monthly income based on your venue type.",
  },
  {
    q: "How does the revenue share work?",
    a: "Carrier revenue is split equally between Mobile Offload and the location partner — you receive 50% of all carrier payments generated by your location. There are no tiered structures, no sliding scales, and no fine print. Your share is paid by the 5th of each month with a full breakdown report.",
  },
  {
    q: "Does this affect my existing internet or Wi-Fi?",
    a: "No. The carrier offload network runs on a completely separate SSID with dedicated bandwidth allocation. Your guest network, internal network, and POS systems are entirely untouched.",
  },
  {
    q: "What carriers are supported?",
    a: "We currently support AT&T, T-Mobile, and Google Fi. Their subscribers connect automatically — no login screen or password required on their end.",
  },
  {
    q: "How long does setup take?",
    a: "Approximately 1 hour. We work with your IT team or network administrator to configure a dedicated SSID and run connectivity tests. Setup is scheduled during off-peak hours to minimize any disruption.",
  },
  {
    q: "What if I want to stop?",
    a: "Either party can exit with 30 days written notice. There are no termination fees, no penalties, and no minimum revenue requirements. On exit, we restore your network to its original configuration.",
  },
];
---

<Base title={title} description={description}>
  <main id="main">
    <Nav />

    <!-- ── HERO ─────────────────────────────────────────────────── -->
    <section class="relative min-h-screen flex items-center overflow-hidden grid-texture" style="padding-top: 4rem; background: var(--color-bg-base);" aria-label="Hero">
      <!-- Background radial glow (matches homepage) -->
      <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
        <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[800px] h-[600px] rounded-full opacity-20"
             style="background: radial-gradient(ellipse at center, #1B6FEB 0%, transparent 70%); filter: blur(80px);"></div>
        <div class="absolute bottom-0 right-0 w-[400px] h-[400px] rounded-full opacity-10"
             style="background: radial-gradient(ellipse at center, #0EA5E9 0%, transparent 70%); filter: blur(60px);"></div>
      </div>

      <div class="relative max-w-7xl mx-auto px-6 py-24 w-full">
        <div class="grid lg:grid-cols-2 gap-16 items-center">

          <!-- Left: Copy -->
          <div>
            <!-- Redding callout -->
            <div class="flex items-center gap-3 mb-6">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--color-success)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              <span style="font-family: var(--font-display); font-size: 1.5rem; font-weight: 700; color: var(--color-success); letter-spacing: -0.01em;">Redding Businesses</span>
            </div>

            <!-- Headline — matches homepage -->
            <h1 class="text-4xl lg:text-5xl xl:text-6xl font-bold mb-6 leading-tight" style="font-family: var(--font-display); letter-spacing: -0.02em;">
              Get Paid When<br/>
              <span class="gradient-text">Mobile Data Is Used</span><br/>
              at Your Location
            </h1>

            <p class="text-lg mb-10 max-w-lg" style="color: var(--color-text-secondary); line-height: 1.7; font-family: var(--font-body);">
              If your Redding location gets steady visitors, your property may be valuable to major mobile carriers looking to reduce network congestion. Mobile Offload helps qualified locations earn monthly income without new hardware, equipment purchases, or changes to daily operations.
            </p>

            <!-- CTAs -->
            <div class="flex flex-col sm:flex-row gap-4 mb-10">
              <a href="#qualify"
                 class="inline-flex items-center justify-center gap-2 px-7 py-4 rounded-xl text-base font-semibold text-white transition-all duration-200 cursor-pointer"
                 style="background: var(--color-primary); font-family: var(--font-body);"
                 onmouseover="this.style.background='var(--color-primary-hover)'; this.style.transform='translateY(-1px)'; this.style.boxShadow='0 8px 32px rgba(27,111,235,0.4)'"
                 onmouseout="this.style.background='var(--color-primary)'; this.style.transform='none'; this.style.boxShadow='none'">
                Check If My Redding Location Qualifies
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
              <a href="#how-it-works"
                 class="inline-flex items-center justify-center gap-2 px-7 py-4 rounded-xl text-base font-medium transition-all duration-200 cursor-pointer"
                 style="background: transparent; border: 1px solid var(--color-border-bright); color: var(--color-text-secondary); font-family: var(--font-body);"
                 onmouseover="this.style.borderColor='var(--color-primary)'; this.style.color='var(--color-text-primary)'"
                 onmouseout="this.style.borderColor='var(--color-border-bright)'; this.style.color='var(--color-text-secondary)'">
                See How It Works
              </a>
            </div>

            <!-- Stats row -->
            <div class="flex flex-wrap gap-8">
              <div>
                <div class="text-3xl font-bold" style="font-family: var(--font-mono); color: var(--color-success);">Monthly Payouts</div>
                <div class="text-sm mt-1" style="color: var(--color-text-muted); font-family: var(--font-body);">Per GB of data offloaded</div>
              </div>
              <div style="width: 1px; background: var(--color-border);"></div>
              <div>
                <div class="text-3xl font-bold" style="font-family: var(--font-mono); color: var(--color-success);">124K+</div>
                <div class="text-sm mt-1" style="color: var(--color-text-muted); font-family: var(--font-body);">Active Subscribers</div>
              </div>
              <div style="width: 1px; background: var(--color-border);"></div>
              <div>
                <div class="text-3xl font-bold" style="font-family: var(--font-mono); color: var(--color-success);">$0</div>
                <div class="text-sm mt-1" style="color: var(--color-text-muted); font-family: var(--font-body);">Upfront Cost</div>
              </div>
            </div>
          </div>

          <!-- Right: Live network animation + revenue range (matches homepage) -->
          <div class="relative hidden lg:block" aria-hidden="true">
            <div class="relative rounded-2xl overflow-hidden" style="background: var(--color-bg-surface); border: 1px solid var(--color-border);">
              <svg id="redd-hero-svg" viewBox="0 -18 480 388" xmlns="http://www.w3.org/2000/svg" class="w-full" aria-label="Live carrier offload network diagram" role="img">
                <defs>
                  <filter id="rhglow-blue" x="-50%" y="-50%" width="200%" height="200%">
                    <feGaussianBlur stdDeviation="3.5" result="blur"/>
                    <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
                  </filter>
                  <filter id="rhglow-green" x="-50%" y="-50%" width="200%" height="200%">
                    <feGaussianBlur stdDeviation="5" result="blur"/>
                    <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
                  </filter>
                  <filter id="rhglow-sm" x="-30%" y="-30%" width="160%" height="160%">
                    <feGaussianBlur stdDeviation="2.5" result="blur"/>
                    <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
                  </filter>
                  <linearGradient id="rhgrad-att" x1="0%" y1="0%" x2="100%" y2="100%">
                    <stop offset="0%" style="stop-color:#00A8E0;stop-opacity:0.9"/>
                    <stop offset="100%" style="stop-color:#1B6FEB;stop-opacity:0.35"/>
                  </linearGradient>
                  <linearGradient id="rhgrad-tmobile" x1="50%" y1="0%" x2="50%" y2="100%">
                    <stop offset="0%" style="stop-color:#E20074;stop-opacity:0.9"/>
                    <stop offset="100%" style="stop-color:#1B6FEB;stop-opacity:0.35"/>
                  </linearGradient>
                  <linearGradient id="rhgrad-fi" x1="100%" y1="0%" x2="0%" y2="100%">
                    <stop offset="0%" style="stop-color:#1A73E8;stop-opacity:0.9"/>
                    <stop offset="100%" style="stop-color:#1B6FEB;stop-opacity:0.35"/>
                  </linearGradient>
                  <linearGradient id="rhgrad-rev" x1="0%" y1="0%" x2="0%" y2="100%">
                    <stop offset="0%" style="stop-color:#1B6FEB;stop-opacity:0.6"/>
                    <stop offset="100%" style="stop-color:#10B981;stop-opacity:0.9"/>
                  </linearGradient>
                  <radialGradient id="rhbuilding-glow" cx="50%" cy="40%" r="50%">
                    <stop offset="0%" style="stop-color:#1B6FEB;stop-opacity:0.22"/>
                    <stop offset="100%" style="stop-color:#1B6FEB;stop-opacity:0"/>
                  </radialGradient>
                  <path id="rh-att"     d="M 88 66 C 140 116 185 152 227 166"/>
                  <path id="rh-tmobile" d="M 240 66 L 240 149"/>
                  <path id="rh-fi"      d="M 392 66 C 340 116 295 152 253 166"/>
                  <path id="rh-rev"     d="M 240 218 L 240 280"/>
                </defs>

                <text x="240" y="-5" text-anchor="middle" fill="rgba(125,153,190,0.45)" font-size="7.5" font-family="var(--font-body)" font-weight="600" letter-spacing="0.12em">CARRIER NETWORK</text>

                <path d="M 88 66 C 140 116 185 152 227 166" stroke="url(#rhgrad-att)" stroke-width="1.5" stroke-dasharray="5 4" fill="none" opacity="0.55"/>
                <path d="M 240 66 L 240 149" stroke="url(#rhgrad-tmobile)" stroke-width="1.5" stroke-dasharray="5 4" fill="none" opacity="0.55"/>
                <path d="M 392 66 C 340 116 295 152 253 166" stroke="url(#rhgrad-fi)" stroke-width="1.5" stroke-dasharray="5 4" fill="none" opacity="0.55"/>
                <path d="M 240 218 L 240 280" stroke="url(#rhgrad-rev)" stroke-width="2" stroke-dasharray="4 3" fill="none" opacity="0.65"/>

                <circle class="redd-pulse rp1" cx="240" cy="188" r="46" fill="none" stroke="#1B6FEB" stroke-width="1"/>
                <circle class="redd-pulse rp2" cx="240" cy="188" r="46" fill="none" stroke="#1B6FEB" stroke-width="1"/>
                <circle class="redd-pulse rp3" cx="240" cy="188" r="46" fill="none" stroke="#1B6FEB" stroke-width="1"/>

                <ellipse cx="240" cy="196" rx="66" ry="54" fill="url(#rhbuilding-glow)"/>

                <line x1="240" y1="140" x2="240" y2="150" stroke="#1B6FEB" stroke-width="1.8" stroke-linecap="round"/>
                <circle cx="240" cy="138" r="2.2" fill="#1B6FEB" opacity="0.85"/>
                <path d="M 233 146 Q 240 140 247 146" stroke="#1B6FEB" stroke-width="1.4" fill="none" stroke-linecap="round" opacity="0.7"/>
                <path d="M 228 149 Q 240 141 252 149" stroke="#1B6FEB" stroke-width="1.1" fill="none" stroke-linecap="round" opacity="0.4"/>

                <rect x="213" y="150" width="54" height="18" rx="1.5" fill="rgba(8,36,90,0.92)" stroke="#1B6FEB" stroke-width="1.5"/>
                <rect x="218" y="153" width="10" height="11" rx="1.5" fill="rgba(14,165,233,0.65)" stroke="rgba(14,165,233,0.3)" stroke-width="0.7"/>
                <rect x="234" y="153" width="10" height="11" rx="1.5" fill="rgba(14,165,233,0.9)" stroke="rgba(14,165,233,0.4)" stroke-width="0.7"/>
                <rect x="250" y="153" width="10" height="11" rx="1.5" fill="rgba(14,165,233,0.5)" stroke="rgba(14,165,233,0.3)" stroke-width="0.7"/>

                <rect x="208" y="167" width="64" height="20" rx="1.5" fill="rgba(10,42,108,0.92)" stroke="#1B6FEB" stroke-width="1.5"/>
                <rect x="213" y="171" width="11" height="12" rx="1.5" fill="rgba(14,165,233,0.45)" stroke="rgba(14,165,233,0.2)" stroke-width="0.7"/>
                <rect x="230" y="171" width="11" height="12" rx="1.5" fill="rgba(14,165,233,0.75)" stroke="rgba(14,165,233,0.35)" stroke-width="0.7"/>
                <rect x="247" y="171" width="11" height="12" rx="1.5" fill="rgba(14,165,233,0.5)" stroke="rgba(14,165,233,0.25)" stroke-width="0.7"/>
                <rect x="263" y="171" width="6" height="12" rx="1.5" fill="rgba(14,165,233,0.3)" stroke="rgba(14,165,233,0.15)" stroke-width="0.7"/>

                <rect x="203" y="186" width="74" height="24" rx="1.5" fill="rgba(12,48,118,0.92)" stroke="#1B6FEB" stroke-width="1.5"/>
                <rect x="207" y="190" width="15" height="15" rx="1.5" fill="rgba(14,165,233,0.4)" stroke="rgba(14,165,233,0.2)" stroke-width="0.7"/>
                <rect x="228" y="190" width="15" height="15" rx="1.5" fill="rgba(14,165,233,0.3)" stroke="rgba(14,165,233,0.2)" stroke-width="0.7"/>
                <rect x="249" y="195" width="16" height="15" rx="2" fill="rgba(27,111,235,0.45)" stroke="#1B6FEB" stroke-width="1.1"/>
                <circle cx="263" cy="202" r="1.6" fill="#1B6FEB" opacity="0.9"/>
                <rect x="271" y="190" width="4" height="15" rx="1" fill="rgba(14,165,233,0.3)" stroke="rgba(14,165,233,0.15)" stroke-width="0.5"/>

                <text x="240" y="225" text-anchor="middle" fill="rgba(255,255,255,0.72)" font-size="9" font-family="var(--font-display)" font-weight="600" letter-spacing="0.06em">YOUR LOCATION</text>

                <rect x="182" y="283" width="116" height="52" rx="12" fill="rgba(4,18,12,0.96)" stroke="#10B981" stroke-width="1.8" filter="url(#rhglow-green)"/>
                <text x="240" y="300" text-anchor="middle" fill="rgba(16,185,129,0.6)" font-size="7.5" font-family="var(--font-body)" font-weight="700" letter-spacing="0.1em">REVENUE EARNED</text>
                <text id="redd-rev" x="240" y="324" text-anchor="middle" fill="#10B981" font-size="21" font-family="var(--font-mono)" font-weight="700">$0.00</text>

                <!-- Packets: AT&T -->
                <circle r="4" fill="#00A8E0" filter="url(#rhglow-sm)" opacity="0.9"><animateMotion dur="2.2s" repeatCount="indefinite" begin="0s"><mpath href="#rh-att"/></animateMotion></circle>
                <circle r="3" fill="#00A8E0" filter="url(#rhglow-sm)" opacity="0.65"><animateMotion dur="2.2s" repeatCount="indefinite" begin="0.8s"><mpath href="#rh-att"/></animateMotion></circle>
                <circle r="2.2" fill="#00A8E0" opacity="0.4"><animateMotion dur="2.2s" repeatCount="indefinite" begin="1.6s"><mpath href="#rh-att"/></animateMotion></circle>
                <!-- Packets: T-Mobile -->
                <circle r="4" fill="#E20074" filter="url(#rhglow-sm)" opacity="0.9"><animateMotion dur="1.9s" repeatCount="indefinite" begin="0.3s"><mpath href="#rh-tmobile"/></animateMotion></circle>
                <circle r="3" fill="#E20074" filter="url(#rhglow-sm)" opacity="0.65"><animateMotion dur="1.9s" repeatCount="indefinite" begin="1.0s"><mpath href="#rh-tmobile"/></animateMotion></circle>
                <circle r="2.2" fill="#E20074" opacity="0.4"><animateMotion dur="1.9s" repeatCount="indefinite" begin="1.6s"><mpath href="#rh-tmobile"/></animateMotion></circle>
                <!-- Packets: Google Fi -->
                <circle r="4" fill="#1A73E8" filter="url(#rhglow-sm)" opacity="0.9"><animateMotion dur="2.4s" repeatCount="indefinite" begin="0.5s"><mpath href="#rh-fi"/></animateMotion></circle>
                <circle r="3" fill="#1A73E8" filter="url(#rhglow-sm)" opacity="0.65"><animateMotion dur="2.4s" repeatCount="indefinite" begin="1.3s"><mpath href="#rh-fi"/></animateMotion></circle>
                <circle r="2.2" fill="#1A73E8" opacity="0.4"><animateMotion dur="2.4s" repeatCount="indefinite" begin="2.0s"><mpath href="#rh-fi"/></animateMotion></circle>
                <!-- Packets: Revenue -->
                <circle r="5" fill="#10B981" filter="url(#rhglow-sm)" opacity="0.95"><animateMotion dur="1.5s" repeatCount="indefinite" begin="1.2s"><mpath href="#rh-rev"/></animateMotion></circle>
                <circle r="3.5" fill="#10B981" filter="url(#rhglow-sm)" opacity="0.75"><animateMotion dur="1.5s" repeatCount="indefinite" begin="2.1s"><mpath href="#rh-rev"/></animateMotion></circle>

                <!-- AT&T node -->
                <circle cx="88" cy="66" r="28" fill="#060F18" stroke="#00A8E0" stroke-width="1.5" filter="url(#rhglow-sm)"/>
                <text x="88" y="62" text-anchor="middle" fill="#00A8E0" font-size="10" font-family="var(--font-display)" font-weight="700">AT&amp;T</text>
                <text x="88" y="77" text-anchor="middle" fill="rgba(125,153,190,0.65)" font-size="8" font-family="var(--font-body)">Carrier</text>
                <!-- T-Mobile node -->
                <circle cx="240" cy="66" r="28" fill="#120010" stroke="#E20074" stroke-width="1.5" filter="url(#rhglow-sm)"/>
                <text x="240" y="62" text-anchor="middle" fill="#E20074" font-size="9.5" font-family="var(--font-display)" font-weight="700">T-Mobile</text>
                <text x="240" y="77" text-anchor="middle" fill="rgba(125,153,190,0.65)" font-size="8" font-family="var(--font-body)">Carrier</text>
                <!-- Google Fi node -->
                <circle cx="392" cy="66" r="28" fill="#060C18" stroke="#1A73E8" stroke-width="1.5" filter="url(#rhglow-sm)"/>
                <text x="392" y="58" text-anchor="middle" fill="#1A73E8" font-size="9.5" font-family="var(--font-display)" font-weight="700">Google</text>
                <text x="392" y="71" text-anchor="middle" fill="#1A73E8" font-size="9.5" font-family="var(--font-display)" font-weight="700">Fi</text>
                <text x="392" y="84" text-anchor="middle" fill="rgba(125,153,190,0.65)" font-size="8" font-family="var(--font-body)">Carrier</text>
              </svg>

              <!-- Live badge -->
              <div class="absolute top-3 left-3 flex items-center gap-2 px-2.5 py-1 rounded-full text-xs font-semibold"
                   style="background: rgba(16,185,129,0.12); border: 1px solid rgba(16,185,129,0.3); color: #10B981; font-family: var(--font-body);">
                <span class="redd-ping w-1.5 h-1.5 rounded-full" style="background: #10B981;"></span>
                Live
              </div>
            </div>

            <!-- Estimated Monthly Range strip below animation -->
            <div class="mt-4 px-5 py-4 rounded-xl flex items-center justify-between gap-4"
                 style="background: var(--color-bg-card); border: 1px solid var(--color-border-bright);">
              <div>
                <div class="text-xs mb-1" style="color: var(--color-text-muted); font-family: var(--font-body);">Estimated Monthly Range</div>
                <div class="text-2xl font-bold" style="font-family: var(--font-mono); color: var(--color-success);">$500 – $9,600+</div>
                <div class="text-xs mt-0.5" style="color: var(--color-text-muted); font-family: var(--font-body);">Varies by location type and foot traffic</div>
              </div>
              <span class="text-xs px-2.5 py-1.5 rounded-full flex-shrink-0"
                    style="background: rgba(16,185,129,0.12); color: var(--color-success); font-family: var(--font-body); border: 1px solid rgba(16,185,129,0.25);">
                Based on real data
              </span>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ── VIDEO PLACEHOLDER ─────────────────────────────────────── -->
    <section class="py-24" style="background: var(--color-bg-surface);">
      <div class="max-w-4xl mx-auto px-6">

        <div class="text-center mb-10">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full mb-6 text-xs font-semibold tracking-widest uppercase"
               style="background: var(--color-primary-muted); color: var(--color-accent); font-family: var(--font-body); border: 1px solid rgba(27,111,235,0.2);">
            Program Overview
          </div>
          <h2 class="text-3xl lg:text-4xl font-bold mb-4" style="font-family: var(--font-display); letter-spacing: -0.02em;">
            See How Mobile Offload Works
          </h2>
          <p class="text-lg max-w-2xl mx-auto" style="color: var(--color-text-secondary); font-family: var(--font-body);">
            A short walkthrough for Redding business owners explaining how the program works and what types of locations may qualify.
          </p>
        </div>

        <!-- Loom video embed -->
        <div class="relative rounded-2xl overflow-hidden"
             style="aspect-ratio: 16/9; box-shadow: 0 12px 48px rgba(0,0,0,0.45); border: 1px solid var(--color-border-bright);">
          <iframe
            src="https://www.loom.com/embed/1f29ef5d49c54f9dabb70c34967bc3fe?hide_owner=true&hide_share=true&hide_title=true&hideEmbedTopBar=true"
            title="Mobile Offload Program Explainer for Redding Business Owners"
            frameborder="0"
            allowfullscreen
            allow="autoplay; fullscreen"
            class="absolute inset-0 w-full h-full"
            loading="lazy"
          ></iframe>
        </div>

      </div>
    </section>

    <!-- ── FOOT TRAFFIC VALUE PROP ────────────────────────────────── -->
    <section class="py-28 relative" style="background: var(--color-bg-base);">
      <div class="absolute left-0 top-1/2 -translate-y-1/2 w-96 h-96 rounded-full opacity-5 pointer-events-none" aria-hidden="true"
