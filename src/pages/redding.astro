  .redd-pulse.rp1 { transform-origin: 240px 188px; }
  .redd-pulse.rp2 { transform-origin: 240px 188px; animation-delay: 1s; }
  .redd-pulse.rp3 { transform-origin: 240px 188px; animation-delay: 2s; }

  @keyframes redd-pulse-expand {
    0%   { r: 38; opacity: 0.5; }
    100% { r: 84; opacity: 0; }
  }

  @keyframes redd-ping {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(1.5); }
  }
  .redd-ping { animation: redd-ping 1.5s ease-in-out infinite; }
</style>

<script>
  // Hero revenue counter
  const reddRev = document.getElementById('redd-rev');
  let reddVal = 0;
  const reddTarget = 47.82;
  const reddInc = reddTarget / (8000 / 50);
  function tickRedd(): void {
    reddVal += reddInc;
    if (reddVal >= reddTarget) reddVal = 0;
    if (reddRev) reddRev.textContent = '$' + reddVal.toFixed(2);
  }
  setInterval(tickRedd, 50);

  // FAQ accordion
  document.querySelectorAll<HTMLButtonElement>('#redding-faq-list .faq-trigger').forEach(trigger => {
    trigger.addEventListener('click', () => {
      const item = trigger.closest('.faq-item') as HTMLElement;
      const answer = trigger.nextElementSibling as HTMLElement;
      const isOpen = item.classList.contains('open');

      // Close all in this list
      document.querySelectorAll<HTMLElement>('#redding-faq-list .faq-item').forEach(el => {
        el.classList.remove('open');
        const ans = el.querySelector<HTMLElement>('.faq-answer');
        const btn = el.querySelector<HTMLButtonElement>('.faq-trigger');
        if (ans) ans.style.maxHeight = '0';
        if (btn) btn.setAttribute('aria-expanded', 'false');
      });

      if (!isOpen) {
        item.classList.add('open');
        answer.style.maxHeight = answer.scrollHeight + 'px';
        trigger.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>
