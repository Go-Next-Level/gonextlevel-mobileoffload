            <div class="mb-4">
              <label for="g-gym-type" class="block text-xs font-semibold mb-2" style="color: var(--color-text-muted); font-family: var(--font-body);">Type of Gym *</label>
              <select id="g-gym-type" name="gym_type" required class="gym-input w-full px-4 py-3 rounded-xl text-sm cursor-pointer">
                <option value="">Select gym type...</option>
                {gymTypes.map(t => <option value={t}>{t}</option>)}
              </select>
            </div>
            <div class="mb-4">
              <label for="g-address" class="block text-xs font-semibold mb-2" style="color: var(--color-text-muted); font-family: var(--font-body);">Gym Address *</label>
              <input id="g-address" name="gym_address" type="text" required autocomplete="street-address"
                     class="gym-input w-full px-4 py-3 rounded-xl text-sm" placeholder="Street address, city, state"/>
