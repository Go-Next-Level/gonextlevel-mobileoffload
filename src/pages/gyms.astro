              <div class="absolute inset-0 pointer-events-none" aria-hidden="true"
                   style="background: radial-gradient(ellipse 60% 50% at 30% 50%, rgba(16,185,129,0.07) 0%, transparent 70%);"></div>
              <div class="relative">
                <div class="inline-flex items-center gap-2 px-2.5 py-1 rounded-lg text-xs font-bold mb-3"
                     style="background: rgba(16,185,129,0.15); color: var(--color-success); font-family: var(--font-body); border: 1px solid rgba(16,185,129,0.3);">
                  <span class="featured-dot"></span> Real Deployment
                </div>
                <div class="text-base font-bold mb-0.5" style="font-family: var(--font-display);">Fitness Center · Irvine, CA</div>
                <div class="text-xs mb-4" style="color: var(--color-text-muted); font-family: var(--font-body);">Brownfield · 1 AP · 1,172 avg daily members</div>
                <div class="grid grid-cols-3 gap-3">
                  <div class="p-3 rounded-xl" style="background: rgba(16,185,129,0.06); border: 1px solid rgba(16,185,129,0.15);">
                    <div class="text-xs mb-1" style="color: rgba(16,185,129,0.6); font-family: var(--font-body);">Monthly</div>
                    <div class="text-lg font-bold" style="font-family: var(--font-mono); color: var(--color-text-primary);">$1,824</div>
                  </div>
                  <div class="p-3 rounded-xl" style="background: rgba(14,165,233,0.06); border: 1px solid rgba(14,165,233,0.15);">
                    <div class="text-xs mb-1" style="color: var(--color-text-muted); font-family: var(--font-body);">Annual</div>
                    <div class="text-lg font-bold" style="font-family: var(--font-mono); color: var(--color-accent);">$22,197</div>
                  </div>
                  <div class="p-3 rounded-xl" style="background: rgba(14,165,233,0.06); border: 1px solid rgba(14,165,233,0.15);">
                    <div class="text-xs mb-1" style="color: var(--color-text-muted); font-family: var(--font-body);">Monthly Data</div>
                    <div class="text-lg font-bold" style="font-family: var(--font-mono); color: var(--color-accent);">7.79 TB</div>
                  </div>
                </div>
              </div>
            </div>

            <a href="#qualify" class="block w-full py-4 px-6 rounded-xl text-center font-semibold text-white transition-all duration-200 cursor-pointer"
               style="background: var(--color-primary); font-family: var(--font-body);"
               onmouseover="this.style.background='var(--color-primary-hover)'"
               onmouseout="this.style.background='var(--color-primary)'">
              See If My Gym Qualifies
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ── HOW IT WORKS ──────────────────────────────────────────── -->
    <section id="how-it-works" class="py-28" style="background: var(--color-bg-surface);">
      <div class="max-w-7xl mx-auto px-6">

        <div class="text-center mb-16">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full mb-6 text-xs font-semibold tracking-widest uppercase"
               style="background: var(--color-primary-muted); color: var(--color-accent); font-family: var(--font-body); border: 1px solid rgba(27,111,235,0.2);">
