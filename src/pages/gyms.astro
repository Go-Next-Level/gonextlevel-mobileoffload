  .gym-preset-btn.gym-preset-active {
    background: var(--color-primary-muted) !important;
    border-color: var(--color-primary) !important;
    color: var(--color-accent) !important;
  }

  /* Hero animation */
  .gym-pulse { animation: gym-pulse-expand 3s ease-out infinite; }
  .gym-pulse.gp1 { transform-origin: 240px 188px; }
  .gym-pulse.gp2 { transform-origin: 240px 188px; animation-delay: 1s; }
  .gym-pulse.gp3 { transform-origin: 240px 188px; animation-delay: 2s; }
  @keyframes gym-pulse-expand {
    0%   { r: 38; opacity: 0.5; }
    100% { r: 84; opacity: 0; }
  }
  @keyframes gym-ping {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.4; transform: scale(1.5); }
  }
  .gym-ping { animation: gym-ping 1.5s ease-in-out infinite; }
</style>

<script define:vars={{ GYM_WEBHOOK }}>
  // ── Hero counter ──
  const gymRevEl = document.getElementById('gym-rev');
  let gymVal = 0;
  const gymTarget = 47.82;
  const gymInc = gymTarget / (8000 / 50);
  function tickGym() {
    gymVal += gymInc;
    if (gymVal >= gymTarget) gymVal = 0;
    if (gymRevEl) gymRevEl.textContent = '$' + gymVal.toFixed(2);
  }
  setInterval(tickGym, 50);

  // ── Gym earnings calculator ──
  const GYM_RATE = 0.044;

  function formatCur(n) {
    if (n >= 1000000) return '$' + (n / 1000000).toFixed(1) + 'M';
    if (n >= 10000)   return '$' + Math.round(n / 1000) + 'K';
    if (n >= 1000)    return '$' + (n / 1000).toFixed(1) + 'K';
    return '$' + Math.round(n).toLocaleString();
  }

  function updateGymCalc(traffic) {
    const monthly = Math.round(GYM_RATE * traffic * 30);
    const annual  = Math.round(GYM_RATE * traffic * 365);
    const mEl = document.getElementById('gym-monthly');
    const aEl = document.getElementById('gym-annual');
    if (mEl) mEl.textContent = formatCur(monthly);
    if (aEl) aEl.textContent = formatCur(annual) + '/yr';
  }

  const gymSlider = document.getElementById('gym-slider');
  const gymDisplay = document.getElementById('gym-traffic-display');

  gymSlider?.addEventListener('input', () => {
    const v = parseInt(gymSlider.value);
    gymSlider.setAttribute('aria-valuenow', String(v));
    if (gymDisplay) gymDisplay.textContent = v.toLocaleString() + ' members/day';
    updateGymCalc(v);
    document.querySelectorAll('.gym-preset-btn').forEach(b => b.classList.remove('gym-preset-active'));
  });

  document.querySelectorAll('.gym-preset-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const v = parseInt(btn.dataset.val);
      if (gymSlider) { gymSlider.value = String(v); gymSlider.setAttribute('aria-valuenow', String(v)); }
      if (gymDisplay) gymDisplay.textContent = v.toLocaleString() + ' members/day';
      document.querySelectorAll('.gym-preset-btn').forEach(b => b.classList.remove('gym-preset-active'));
      btn.classList.add('gym-preset-active');
      updateGymCalc(v);
    });
  });

  updateGymCalc(400);

  // ── Wi-Fi "Other" conditional ──
  const wifiSel = document.getElementById('g-wifi');
  const wifiOtherWrap = document.getElementById('g-wifi-other-wrap');
  wifiSel?.addEventListener('change', () => {
    if (wifiSel.value === 'Other (please specify)') {
      wifiOtherWrap?.classList.remove('hidden');
    } else {
      wifiOtherWrap?.classList.add('hidden');
    }
  });

  // ── Consent checkbox ──
  let consentChecked = false;
  const consentBox = document.getElementById('gym-consent-box');
  const consentRow = document.getElementById('gym-consent-row');

  function toggleConsent() {
    consentChecked = !consentChecked;
    if (consentBox) {
      consentBox.setAttribute('aria-checked', String(consentChecked));
      consentBox.style.background = consentChecked ? 'var(--color-primary)' : 'var(--color-bg-base)';
      consentBox.style.borderColor = consentChecked ? 'var(--color-primary)' : 'var(--color-border-bright)';
      consentBox.innerHTML = consentChecked
        ? '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>'
        : '';
    }
  }
  consentRow?.addEventListener('click', toggleConsent);
  consentBox?.addEventListener('keydown', e => { if (e.key === ' ' || e.key === 'Enter') { e.preventDefault(); toggleConsent(); } });

  // ── Multi-step form ──
  const TOTAL_STEPS = 3;
  let currentStep = 1;

  const btnNext   = document.getElementById('gym-btn-next');
  const btnBack   = document.getElementById('gym-btn-back');
  const btnSubmit = document.getElementById('gym-btn-submit');
  const errorMsg  = document.getElementById('gym-error-msg');

  function getStepFields(step) {
    const map = {
      1: ['g-first', 'g-last', 'g-email', 'g-phone'],
      2: ['g-gym-name', 'g-gym-type', 'g-address', 'g-locations'],
      3: ['g-members'],
    };
    return map[step] || [];
  }

  function validateStep(step) {
    const ids = getStepFields(step);
    let valid = true;
    ids.forEach(id => {
      const el = document.getElementById(id);
      if (el && el.hasAttribute('required') && !el.value.trim()) valid = false;
    });
    if (step === 3 && !consentChecked) valid = false;
    return valid;
  }

  function updateStepUI() {
    for (let i = 1; i <= TOTAL_STEPS; i++) {
      document.getElementById(`gym-step-${i}`)?.classList.toggle('hidden', i !== currentStep);
      const dot = document.getElementById(`gym-dot-${i}`);
      if (dot) {
        if (i < currentStep) {
          dot.style.background = 'var(--color-success)';
          dot.style.color = 'white';
          dot.innerHTML = '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>';
        } else if (i === currentStep) {
          dot.style.background = 'var(--color-primary)';
          dot.style.color = 'white';
          dot.innerHTML = String(i);
        } else {
          dot.style.background = 'var(--color-border)';
          dot.style.color = 'var(--color-text-muted)';
          dot.innerHTML = String(i);
        }
      }
    }
    const pct = Math.round((currentStep / TOTAL_STEPS) * 100);
    const bar = document.getElementById('gym-progress-bar');
    const pctEl = document.getElementById('gym-progress-pct');
    const labelEl = document.getElementById('gym-step-label');
    if (bar) bar.style.width = pct + '%';
    if (pctEl) pctEl.textContent = String(pct);
    if (labelEl) labelEl.textContent = String(currentStep);

    btnBack?.classList.toggle('hidden', currentStep === 1);
    btnNext?.classList.toggle('hidden', currentStep === TOTAL_STEPS);
    btnSubmit?.classList.toggle('hidden', currentStep !== TOTAL_STEPS);
    errorMsg?.classList.add('hidden');
  }

  btnNext?.addEventListener('click', () => {
    if (!validateStep(currentStep)) { errorMsg?.classList.remove('hidden'); return; }
    currentStep = Math.min(currentStep + 1, TOTAL_STEPS);
    updateStepUI();
    document.getElementById('gym-qualify-form')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });

  btnBack?.addEventListener('click', () => {
    currentStep = Math.max(currentStep - 1, 1);
    updateStepUI();
    document.getElementById('gym-qualify-form')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });

  // ── Submit ──
  document.getElementById('gym-qualify-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!validateStep(TOTAL_STEPS)) { errorMsg?.classList.remove('hidden'); return; }

    if (btnSubmit) btnSubmit.disabled = true;
    const submitText = document.getElementById('gym-submit-text');
    if (submitText) submitText.textContent = 'Submitting...';

    const get = (id) => document.getElementById(id)?.value?.trim() ?? '';

    const wifiVal = get('g-wifi') === 'Other (please specify)'
      ? 'Other: ' + get('g-wifi-other')
      : get('g-wifi');

    const payload = {
      firstName:      get('g-first'),
      lastName:       get('g-last'),
      email:          get('g-email'),
      phone:          get('g-phone'),
      name:           (get('g-first') + ' ' + get('g-last')).trim(),
      gymName:        get('g-gym-name'),
      gymType:        get('g-gym-type'),
      gymAddress:     get('g-address'),
      numLocations:   get('g-locations'),
      dailyMembers:   get('g-members'),
      wifiController: wifiVal,
      heardFrom:      get('g-heard'),
      message:        get('g-message'),
      consentGiven:   'Yes',
      source:         'Mobile Offload — Gym Qualification Form',
      tags:           ['mobile-offload-gym-lead'],
    };

    try {
      const res = await fetch(GYM_WEBHOOK, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      if (res.ok) {
        window.location.href = '/thank-you';
      } else {
        throw new Error('Webhook error');
      }
    } catch {
      errorMsg?.classList.remove('hidden');
      if (btnSubmit) btnSubmit.disabled = false;
      if (submitText) submitText.textContent = 'Submit My Gym';
    }
  });
</script>
