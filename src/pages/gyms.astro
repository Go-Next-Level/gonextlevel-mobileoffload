              <div id="gym-annual" class="text-3xl font-bold" style="font-family: var(--font-mono); color: var(--color-text-primary);">$6.4K/yr</div>
            </div>

            <!-- Real deployment example -->
            <div class="p-6 rounded-2xl featured-card relative overflow-hidden"
