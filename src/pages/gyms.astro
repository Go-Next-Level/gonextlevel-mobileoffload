            </div>
            <div class="mb-4">
              <label for="g-heard" class="block text-xs font-semibold mb-2" style="color: var(--color-text-muted); font-family: var(--font-body);">How Did You Hear About Us?</label>
              <select id="g-heard" name="heard_from" class="gym-input w-full px-4 py-3 rounded-xl text-sm cursor-pointer">
                <option value="">Select...</option>
                {heardFromOptions.map(o => <option value={o}>{o}</option>)}
              </select>
            </div>
            <div class="mb-6">
              <label for="g-message" class="block text-xs font-semibold mb-2" style="color: var(--color-text-muted); font-family: var(--font-body);">Anything Else We Should Know? (optional)</label>
              <textarea id="g-message" name="message" rows="3"
                        class="gym-input w-full px-4 py-3 rounded-xl text-sm resize-none" placeholder="Any questions, context about your facility, or details that may help..."></textarea>
            </div>

            <!-- Consent -->
            <div class="mb-6 p-4 rounded-xl" style="background: var(--color-bg-elevated); border: 1px solid var(--color-border);">
              <div class="flex items-start gap-3 cursor-pointer" id="gym-consent-row">
                <div id="gym-consent-box"
                     class="w-5 h-5 rounded flex items-center justify-center flex-shrink-0 mt-0.5 transition-all duration-200 cursor-pointer"
                     style="background: var(--color-bg-base); border: 2px solid var(--color-border-bright);"
                     role="checkbox" aria-checked="false" tabindex="0">
                </div>
                <p class="text-xs leading-relaxed" style="color: var(--color-text-secondary); font-family: var(--font-body);">
                  I understand and agree that by submitting this form, I am giving Goolsby Ventures LLC (Mobile Offload) and its partner Hudson House permission to contact me by phone, email, or text regarding carrier offload network services. I have read and agree to the <a href="/privacy-policy" style="color: var(--color-accent);" target="_blank">Privacy Policy</a>.
                </p>
              </div>
            </div>
          </div>

          <!-- Error message -->
          <div id="gym-error-msg" class="hidden mb-4 px-4 py-3 rounded-xl text-sm" style="background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.3); color: #F87171; font-family: var(--font-body);">
            Please fill in all required fields before continuing.
          </div>

          <!-- Navigation -->
          <div class="flex items-center justify-between gap-4">
            <button type="button" id="gym-btn-back"
                    class="hidden px-6 py-3 rounded-xl text-sm font-semibold transition-all duration-200 cursor-pointer"
                    style="background: var(--color-bg-elevated); border: 1px solid var(--color-border-bright); color: var(--color-text-secondary); font-family: var(--font-body);">
              ← Back
            </button>
            <button type="button" id="gym-btn-next"
                    class="ml-auto px-8 py-3 rounded-xl text-sm font-semibold text-white transition-all duration-200 cursor-pointer"
                    style="background: var(--color-primary); font-family: var(--font-body);">
              Next →
