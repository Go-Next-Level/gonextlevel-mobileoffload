              </select>
            </div>
            <div id="g-wifi-other-wrap" class="mb-4 hidden">
              <label for="g-wifi-other" class="block text-xs font-semibold mb-2" style="color: var(--color-text-muted); font-family: var(--font-body);">Please specify</label>
              <input id="g-wifi-other" name="wifi_controller_other" type="text"
