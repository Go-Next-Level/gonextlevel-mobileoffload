                <div id={`gym-dot-${i+1}`} class="w-6 h-6 rounded-full flex items-center justify-center text-xs font-bold transition-all duration-300"
                     style={`background: ${i === 0 ? 'var(--color-primary)' : 'var(--color-border)'}; color: ${i === 0 ? 'white' : 'var(--color-text-muted)'}; font-family: var(--font-mono);`}>
                  {i + 1}
                </div>
                <span class="text-xs" style="color: var(--color-text-muted); font-family: var(--font-body);">{label}</span>
              </div>
            ))}
          </div>
        </div>

        <form id="gym-qualify-form" novalidate
              class="p-8 rounded-2xl" style="background: var(--color-bg-card); border: 1px solid var(--color-border-bright);">

          <!-- Step 1: Contact Info -->
          <div id="gym-step-1" class="gym-step">
            <h3 class="text-lg font-bold mb-6" style="font-family: var(--font-display);">Your Contact Information</h3>
            <div class="grid grid-cols-2 gap-4 mb-4">
              <div>
                <label for="g-first" class="block text-xs font-semibold mb-2" style="color: var(--color-text-muted); font-family: var(--font-body);">First Name *</label>
                <input id="g-first" name="first_name" type="text" required autocomplete="given-name"
                       class="gym-input w-full px-4 py-3 rounded-xl text-sm" placeholder="First name"/>
              </div>
              <div>
                <label for="g-last" class="block text-xs font-semibold mb-2" style="color: var(--color-text-muted); font-family: var(--font-body);">Last Name *</label>
                <input id="g-last" name="last_name" type="text" required autocomplete="family-name"
                       class="gym-input w-full px-4 py-3 rounded-xl text-sm" placeholder="Last name"/>
              </div>
            </div>
            <div class="mb-4">
              <label for="g-email" class="block text-xs font-semibold mb-2" style="color: var(--color-text-muted); font-family: var(--font-body);">Email Address *</label>
              <input id="g-email" name="email" type="email" required autocomplete="email"
                     class="gym-input w-full px-4 py-3 rounded-xl text-sm" placeholder="you@yourgym.com"/>
            </div>
            <div class="mb-6">
              <label for="g-phone" class="block text-xs font-semibold mb-2" style="color: var(--color-text-muted); font-family: var(--font-body);">Phone Number *</label>
              <input id="g-phone" name="phone" type="tel" required autocomplete="tel"
