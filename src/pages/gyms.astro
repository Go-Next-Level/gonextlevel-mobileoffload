            </div>
          </div>

          <!-- Step 2: Gym Info -->
          <div id="gym-step-2" class="gym-step hidden">
            <h3 class="text-lg font-bold mb-6" style="font-family: var(--font-display);">About Your Gym</h3>
            <div class="mb-4">
              <label for="g-gym-name" class="block text-xs font-semibold mb-2" style="color: var(--color-text-muted); font-family: var(--font-body);">Gym / Facility Name *</label>
