          <p class="text-base" style="color: var(--color-text-secondary); font-family: var(--font-body); line-height: 1.7;">
            Not every gym will qualify. Eligibility depends on member volume, facility size, and carrier demand in your area. Fill out the form below and we'll review your location.
          </p>
        </div>

        <!-- Progress bar -->
        <div class="mb-8">
          <div class="flex items-center justify-between mb-2">
            <span class="text-xs font-semibold" style="color: var(--color-text-muted); font-family: var(--font-body);">Step <span id="gym-step-label">1</span> of 3</span>
            <span class="text-xs font-semibold" style="color: var(--color-accent); font-family: var(--font-body);"><span id="gym-progress-pct">33</span>%</span>
          </div>
          <div class="w-full h-1.5 rounded-full" style="background: var(--color-border);">
