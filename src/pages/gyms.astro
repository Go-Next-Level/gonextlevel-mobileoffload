    <!-- ── GYM QUALIFY FORM ──────────────────────────────────────── -->
    <section id="qualify" class="py-28 relative overflow-hidden" style="background: var(--color-bg-base);">
      <div class="absolute inset-0 pointer-events-none" aria-hidden="true"
           style="background: radial-gradient(ellipse 50% 60% at 50% 20%, rgba(27,111,235,0.06) 0%, transparent 70%);"></div>

      <div class="relative max-w-2xl mx-auto px-6">
        <div class="text-center mb-12">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full mb-6 text-xs font-semibold tracking-widest uppercase"
               style="background: var(--color-primary-muted); color: var(--color-accent); font-family: var(--font-body); border: 1px solid rgba(27,111,235,0.2);">
            Gym Qualification
          </div>
          <h2 class="text-3xl lg:text-4xl font-bold mb-4" style="font-family: var(--font-display); letter-spacing: -0.02em;">
