        </div>

        <!-- Guarantees bar -->
        <div class="p-6 rounded-2xl flex flex-col md:flex-row items-center gap-6"
             style="background: var(--color-primary-muted); border: 1px solid rgba(27,111,235,0.25);">
          {[
            { icon: `<circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>`, label: "~1 Hour Setup", sub: "Scheduled during off-peak hours" },
            { icon: `<path d="M20 6L9 17l-5-5"/>`, label: "Zero Member Disruption", sub: "Completely invisible to your members" },
            { icon: `<rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>`, label: "Month-to-Month", sub: "Exit anytime with 30 days notice" },
          ].map((item, i) => (
            <>
              <div class="flex items-center gap-3">
