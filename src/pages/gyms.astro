            <button type="submit" id="gym-btn-submit"
                    class="hidden ml-auto px-8 py-3 rounded-xl text-sm font-semibold text-white transition-all duration-200 cursor-pointer"
                    style="background: var(--color-primary); font-family: var(--font-body);">
              <span id="gym-submit-text">Submit My Gym</span>
            </button>
          </div>

        </form>

        <p class="text-center text-xs mt-6" style="color: var(--color-text-muted); font-family: var(--font-body);">
          No commitment required. We'll review your gym and reach out within 1–2 business days.
        </p>
      </div>
    </section>

    <Footer />
  </main>
</Base>

