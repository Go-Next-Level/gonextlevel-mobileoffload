---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const title = "Mobile Offload for Gyms | Earn Monthly Income From Member Foot Traffic";
const description = "Gym and fitness center owners may qualify for monthly carrier program income through Mobile Offload. No hardware purchase, no equipment cost, and no disruption to your members or operations.";

const GYM_WEBHOOK = 'https://services.leadconnectorhq.com/hooks/4aIMOOEHb5YojmrdglB9/webhook-trigger/7d700d2f-c93f-4696-b9a8-94dae4dc80c9';

const gymTypes = [
  "CrossFit Box",
  "Commercial / Traditional Gym",
  "Boutique Fitness Studio",
  "Yoga / Pilates Studio",
  "Martial Arts / MMA",
  "Functional Fitness",
  "Personal Training Studio",
  "Other",
];

const wifiControllers = [
  "Aruba",
  "Cambium cnMaestro",
  "Fortinet",
  "Juniper Mist",
  "Meraki",
  "Cisco Catalyst 9800",
  "Cisco Catalyst 5520",
  "MikroTik",
  "Ruckus",
  "Ubiquiti",
  "Other (please specify)",
  "Not Sure",
];

const heardFromOptions = [
  "Google Search",
  "Social Media",
  "Referral from another gym owner",
  "Email",
  "Podcast or Video",
  "Other",
];

const steps = [
  {
    num: "01",
    title: "We Assess Your Location",
    body: "Submit your gym info and we review your location type, member volume, and existing network to confirm eligibility.",
  },
  {
    num: "02",
    title: "Software-Only Setup",
    body: "If your gym qualifies, we configure a dedicated carrier SSID on your existing equipment. No new hardware. Takes about an hour.",
  },
  {
    num: "03",
    title: "Members Connect Automatically",
    body: "AT&T, T-Mobile, and Google Fi subscribers automatically offload to your network when they're in your gym. No passwords, no friction.",
  },
  {
    num: "04",
    title: "You Get Paid Monthly",
    body: "Receive 50% of all carrier revenue generated by your gym, paid by the 5th of each month with a full data report.",
  },
];
---

<Base title={title} description={description}>
  <main id="main">
    <Nav />

    <!-- ── HERO ─────────────────────────────────────────────────── -->
    <section class="relative min-h-screen flex items-center overflow-hidden grid-texture" style="padding-top: 4rem; background: var(--color-bg-base);" aria-label="Hero">
      <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
        <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[800px] h-[600px] rounded-full opacity-20"
             style="background: radial-gradient(ellipse at center, #1B6FEB 0%, transparent 70%); filter: blur(80px);"></div>
        <div class="absolute bottom-0 right-0 w-[400px] h-[400px] rounded-full opacity-10"
             style="background: radial-gradient(ellipse at center, #10B981 0%, transparent 70%); filter: blur(60px);"></div>
      </div>

      <div class="relative max-w-7xl mx-auto px-6 py-24 w-full">
        <div class="grid lg:grid-cols-2 gap-16 items-center">

          <!-- Left -->
          <div>
            <div class="flex items-center gap-3 mb-6">
              <span style="font-size: 1.75rem;" aria-hidden="true">🏋️</span>
              <span style="font-family: var(--font-display); font-size: 1.5rem; font-weight: 700; color: var(--color-success); letter-spacing: -0.01em;">Gym Owners</span>
            </div>

            <h1 class="text-4xl lg:text-5xl xl:text-6xl font-bold mb-6 leading-tight" style="font-family: var(--font-display); letter-spacing: -0.02em;">
              Get Paid When<br/>
              <span class="gradient-text">Mobile Data Is Used</span><br/>
              at Your Gym
            </h1>

            <p class="text-lg mb-10 max-w-lg" style="color: var(--color-text-secondary); line-height: 1.7; font-family: var(--font-body);">
              Your members stream music, podcasts, and YouTube for 1–2 hours every visit. Major carriers pay to offload that data through your facility. Mobile Offload connects qualified gyms with those carrier payments — no new equipment, no disruption, no cost.
            </p>

            <div class="flex flex-col sm:flex-row gap-4 mb-10">
              <a href="#qualify"
                 class="inline-flex items-center justify-center gap-2 px-7 py-4 rounded-xl text-base font-semibold text-white transition-all duration-200 cursor-pointer"
                 style="background: var(--color-primary); font-family: var(--font-body);"
                 onmouseover="this.style.background='var(--color-primary-hover)'; this.style.transform='translateY(-1px)'; this.style.boxShadow='0 8px 32px rgba(27,111,235,0.4)'"
                 onmouseout="this.style.background='var(--color-primary)'; this.style.transform='none'; this.style.boxShadow='none'">
                See If My Gym Qualifies
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
              <a href="#how-it-works"
                 class="inline-flex items-center justify-center gap-2 px-7 py-4 rounded-xl text-base font-medium transition-all duration-200 cursor-pointer"
                 style="background: transparent; border: 1px solid var(--color-border-bright); color: var(--color-text-secondary); font-family: var(--font-body);"
                 onmouseover="this.style.borderColor='var(--color-primary)'; this.style.color='var(--color-text-primary)'"
                 onmouseout="this.style.borderColor='var(--color-border-bright)'; this.style.color='var(--color-text-secondary)'">
                See How It Works
              </a>
            </div>

            <!-- Stats -->
            <div class="flex flex-wrap gap-8">
              <div>
                <div class="text-3xl font-bold" style="font-family: var(--font-mono); color: var(--color-success);">Monthly Payouts</div>
                <div class="text-sm mt-1" style="color: var(--color-text-muted); font-family: var(--font-body);">Per GB of data offloaded</div>
              </div>
              <div style="width: 1px; background: var(--color-border);"></div>
              <div>
                <div class="text-3xl font-bold" style="font-family: var(--font-mono); color: var(--color-success);">$0</div>
                <div class="text-sm mt-1" style="color: var(--color-text-muted); font-family: var(--font-body);">Equipment Cost</div>
              </div>
              <div style="width: 1px; background: var(--color-border);"></div>
              <div>
                <div class="text-3xl font-bold" style="font-family: var(--font-mono); color: var(--color-success);">50%</div>
                <div class="text-sm mt-1" style="color: var(--color-text-muted); font-family: var(--font-body);">Revenue Share to You</div>
              </div>
            </div>
          </div>

          <!-- Right: Animation -->
          <div class="relative hidden lg:block" aria-hidden="true">
            <div class="relative rounded-2xl overflow-hidden" style="background: var(--color-bg-surface); border: 1px solid var(--color-border);">
              <svg id="gym-hero-svg" viewBox="0 -18 480 388" xmlns="http://www.w3.org/2000/svg" class="w-full" role="img" aria-label="Live carrier offload network diagram">
                <defs>
                  <filter id="ghglow-blue" x="-50%" y="-50%" width="200%" height="200%">
                    <feGaussianBlur stdDeviation="3.5" result="blur"/>
                    <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
                  </filter>
                  <filter id="ghglow-green" x="-50%" y="-50%" width="200%" height="200%">
                    <feGaussianBlur stdDeviation="5" result="blur"/>
                    <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
                  </filter>
                  <filter id="ghglow-sm" x="-30%" y="-30%" width="160%" height="160%">
                    <feGaussianBlur stdDeviation="2.5" result="blur"/>
                    <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
                  </filter>
                  <linearGradient id="ghgrad-att" x1="0%" y1="0%" x2="100%" y2="100%">
                    <stop offset="0%" style="stop-color:#00A8E0;stop-opacity:0.9"/>
                    <stop offset="100%" style="stop-color:#1B6FEB;stop-opacity:0.35"/>
                  </linearGradient>
                  <linearGradient id="ghgrad-tmobile" x1="50%" y1="0%" x2="50%" y2="100%">
                    <stop offset="0%" style="stop-color:#E20074;stop-opacity:0.9"/>
                    <stop offset="100%" style="stop-color:#1B6FEB;stop-opacity:0.35"/>
                  </linearGradient>
                  <linearGradient id="ghgrad-fi" x1="100%" y1="0%" x2="0%" y2="100%">
                    <stop offset="0%" style="stop-color:#1A73E8;stop-opacity:0.9"/>
                    <stop offset="100%" style="stop-color:#1B6FEB;stop-opacity:0.35"/>
                  </linearGradient>
                  <linearGradient id="ghgrad-rev" x1="0%" y1="0%" x2="0%" y2="100%">
                    <stop offset="0%" style="stop-color:#1B6FEB;stop-opacity:0.6"/>
                    <stop offset="100%" style="stop-color:#10B981;stop-opacity:0.9"/>
                  </linearGradient>
                  <radialGradient id="ghbuilding-glow" cx="50%" cy="40%" r="50%">
                    <stop offset="0%" style="stop-color:#1B6FEB;stop-opacity:0.22"/>
                    <stop offset="100%" style="stop-color:#1B6FEB;stop-opacity:0"/>
                  </radialGradient>
                  <path id="gh-att"     d="M 88 66 C 140 116 185 152 227 166"/>
                  <path id="gh-tmobile" d="M 240 66 L 240 149"/>
                  <path id="gh-fi"      d="M 392 66 C 340 116 295 152 253 166"/>
                  <path id="gh-rev"     d="M 240 218 L 240 280"/>
                </defs>

                <text x="240" y="-5" text-anchor="middle" fill="rgba(125,153,190,0.45)" font-size="7.5" font-family="var(--font-body)" font-weight="600" letter-spacing="0.12em">CARRIER NETWORK</text>

                <path d="M 88 66 C 140 116 185 152 227 166" stroke="url(#ghgrad-att)" stroke-width="1.5" stroke-dasharray="5 4" fill="none" opacity="0.55"/>
                <path d="M 240 66 L 240 149" stroke="url(#ghgrad-tmobile)" stroke-width="1.5" stroke-dasharray="5 4" fill="none" opacity="0.55"/>
                <path d="M 392 66 C 340 116 295 152 253 166" stroke="url(#ghgrad-fi)" stroke-width="1.5" stroke-dasharray="5 4" fill="none" opacity="0.55"/>
                <path d="M 240 218 L 240 280" stroke="url(#ghgrad-rev)" stroke-width="2" stroke-dasharray="4 3" fill="none" opacity="0.65"/>

                <circle class="gym-pulse gp1" cx="240" cy="188" r="46" fill="none" stroke="#1B6FEB" stroke-width="1"/>
                <circle class="gym-pulse gp2" cx="240" cy="188" r="46" fill="none" stroke="#1B6FEB" stroke-width="1"/>
                <circle class="gym-pulse gp3" cx="240" cy="188" r="46" fill="none" stroke="#1B6FEB" stroke-width="1"/>

                <ellipse cx="240" cy="196" rx="66" ry="54" fill="url(#ghbuilding-glow)"/>

                <line x1="240" y1="140" x2="240" y2="150" stroke="#1B6FEB" stroke-width="1.8" stroke-linecap="round"/>
                <circle cx="240" cy="138" r="2.2" fill="#1B6FEB" opacity="0.85"/>
                <path d="M 233 146 Q 240 140 247 146" stroke="#1B6FEB" stroke-width="1.4" fill="none" stroke-linecap="round" opacity="0.7"/>
                <path d="M 228 149 Q 240 141 252 149" stroke="#1B6FEB" stroke-width="1.1" fill="none" stroke-linecap="round" opacity="0.4"/>

                <rect x="213" y="150" width="54" height="18" rx="1.5" fill="rgba(8,36,90,0.92)" stroke="#1B6FEB" stroke-width="1.5"/>
                <rect x="218" y="153" width="10" height="11" rx="1.5" fill="rgba(14,165,233,0.65)" stroke="rgba(14,165,233,0.3)" stroke-width="0.7"/>
                <rect x="234" y="153" width="10" height="11" rx="1.5" fill="rgba(14,165,233,0.9)" stroke="rgba(14,165,233,0.4)" stroke-width="0.7"/>
                <rect x="250" y="153" width="10" height="11" rx="1.5" fill="rgba(14,165,233,0.5)" stroke="rgba(14,165,233,0.3)" stroke-width="0.7"/>
                <rect x="208" y="167" width="64" height="20" rx="1.5" fill="rgba(10,42,108,0.92)" stroke="#1B6FEB" stroke-width="1.5"/>
                <rect x="213" y="171" width="11" height="12" rx="1.5" fill="rgba(14,165,233,0.45)" stroke="rgba(14,165,233,0.2)" stroke-width="0.7"/>
                <rect x="230" y="171" width="11" height="12" rx="1.5" fill="rgba(14,165,233,0.75)" stroke="rgba(14,165,233,0.35)" stroke-width="0.7"/>
                <rect x="247" y="171" width="11" height="12" rx="1.5" fill="rgba(14,165,233,0.5)" stroke="rgba(14,165,233,0.25)" stroke-width="0.7"/>
                <rect x="263" y="171" width="6" height="12" rx="1.5" fill="rgba(14,165,233,0.3)" stroke="rgba(14,165,233,0.15)" stroke-width="0.7"/>
                <rect x="203" y="186" width="74" height="24" rx="1.5" fill="rgba(12,48,118,0.92)" stroke="#1B6FEB" stroke-width="1.5"/>
                <rect x="207" y="190" width="15" height="15" rx="1.5" fill="rgba(14,165,233,0.4)" stroke="rgba(14,165,233,0.2)" stroke-width="0.7"/>
                <rect x="228" y="190" width="15" height="15" rx="1.5" fill="rgba(14,165,233,0.3)" stroke="rgba(14,165,233,0.2)" stroke-width="0.7"/>
                <rect x="249" y="195" width="16" height="15" rx="2" fill="rgba(27,111,235,0.45)" stroke="#1B6FEB" stroke-width="1.1"/>
                <circle cx="263" cy="202" r="1.6" fill="#1B6FEB" opacity="0.9"/>
                <rect x="271" y="190" width="4" height="15" rx="1" fill="rgba(14,165,233,0.3)" stroke="rgba(14,165,233,0.15)" stroke-width="0.5"/>

                <text x="240" y="225" text-anchor="middle" fill="rgba(255,255,255,0.72)" font-size="9" font-family="var(--font-display)" font-weight="600" letter-spacing="0.06em">YOUR GYM</text>

                <rect x="182" y="283" width="116" height="52" rx="12" fill="rgba(4,18,12,0.96)" stroke="#10B981" stroke-width="1.8" filter="url(#ghglow-green)"/>
                <text x="240" y="300" text-anchor="middle" fill="rgba(16,185,129,0.6)" font-size="7.5" font-family="var(--font-body)" font-weight="700" letter-spacing="0.1em">REVENUE EARNED</text>
                <text id="gym-rev" x="240" y="324" text-anchor="middle" fill="#10B981" font-size="21" font-family="var(--font-mono)" font-weight="700">$0.00</text>

                <circle r="4" fill="#00A8E0" filter="url(#ghglow-sm)" opacity="0.9"><animateMotion dur="2.2s" repeatCount="indefinite" begin="0s"><mpath href="#gh-att"/></animateMotion></circle>
                <circle r="3" fill="#00A8E0" filter="url(#ghglow-sm)" opacity="0.65"><animateMotion dur="2.2s" repeatCount="indefinite" begin="0.8s"><mpath href="#gh-att"/></animateMotion></circle>
                <circle r="2.2" fill="#00A8E0" opacity="0.4"><animateMotion dur="2.2s" repeatCount="indefinite" begin="1.6s"><mpath href="#gh-att"/></animateMotion></circle>
                <circle r="4" fill="#E20074" filter="url(#ghglow-sm)" opacity="0.9"><animateMotion dur="1.9s" repeatCount="indefinite" begin="0.3s"><mpath href="#gh-tmobile"/></animateMotion></circle>
                <circle r="3" fill="#E20074" filter="url(#ghglow-sm)" opacity="0.65"><animateMotion dur="1.9s" repeatCount="indefinite" begin="1.0s"><mpath href="#gh-tmobile"/></animateMotion></circle>
                <circle r="2.2" fill="#E20074" opacity="0.4"><animateMotion dur="1.9s" repeatCount="indefinite" begin="1.6s"><mpath href="#gh-tmobile"/></animateMotion></circle>
                <circle r="4" fill="#1A73E8" filter="url(#ghglow-sm)" opacity="0.9"><animateMotion dur="2.4s" repeatCount="indefinite" begin="0.5s"><mpath href="#gh-fi"/></animateMotion></circle>
                <circle r="3" fill="#1A73E8" filter="url(#ghglow-sm)" opacity="0.65"><animateMotion dur="2.4s" repeatCount="indefinite" begin="1.3s"><mpath href="#gh-fi"/></animateMotion></circle>
                <circle r="2.2" fill="#1A73E8" opacity="0.4"><animateMotion dur="2.4s" repeatCount="indefinite" begin="2.0s"><mpath href="#gh-fi"/></animateMotion></circle>
                <circle r="5" fill="#10B981" filter="url(#ghglow-sm)" opacity="0.95"><animateMotion dur="1.5s" repeatCount="indefinite" begin="1.2s"><mpath href="#gh-rev"/></animateMotion></circle>
                <circle r="3.5" fill="#10B981" filter="url(#ghglow-sm)" opacity="0.75"><animateMotion dur="1.5s" repeatCount="indefinite" begin="2.1s"><mpath href="#gh-rev"/></animateMotion></circle>

                <circle cx="88" cy="66" r="28" fill="#060F18" stroke="#00A8E0" stroke-width="1.5" filter="url(#ghglow-sm)"/>
                <text x="88" y="62" text-anchor="middle" fill="#00A8E0" font-size="10" font-family="var(--font-display)" font-weight="700">AT&amp;T</text>
                <text x="88" y="77" text-anchor="middle" fill="rgba(125,153,190,0.65)" font-size="8" font-family="var(--font-body)">Carrier</text>
                <circle cx="240" cy="66" r="28" fill="#120010" stroke="#E20074" stroke-width="1.5" filter="url(#ghglow-sm)"/>
                <text x="240" y="62" text-anchor="middle" fill="#E20074" font-size="9.5" font-family="var(--font-display)" font-weight="700">T-Mobile</text>
                <text x="240" y="77" text-anchor="middle" fill="rgba(125,153,190,0.65)" font-size="8" font-family="var(--font-body)">Carrier</text>
                <circle cx="392" cy="66" r="28" fill="#060C18" stroke="#1A73E8" stroke-width="1.5" filter="url(#ghglow-sm)"/>
                <text x="392" y="58" text-anchor="middle" fill="#1A73E8" font-size="9.5" font-family="var(--font-display)" font-weight="700">Google</text>
                <text x="392" y="71" text-anchor="middle" fill="#1A73E8" font-size="9.5" font-family="var(--font-display)" font-weight="700">Fi</text>
                <text x="392" y="84" text-anchor="middle" fill="rgba(125,153,190,0.65)" font-size="8" font-family="var(--font-body)">Carrier</text>
              </svg>

              <div class="absolute top-3 left-3 flex items-center gap-2 px-2.5 py-1 rounded-full text-xs font-semibold"
                   style="background: rgba(16,185,129,0.12); border: 1px solid rgba(16,185,129,0.3); color: #10B981; font-family: var(--font-body);">
                <span class="gym-ping w-1.5 h-1.5 rounded-full" style="background: #10B981;"></span>
                Live
              </div>
            </div>

            <!-- Revenue strip -->
            <div class="mt-4 px-5 py-4 rounded-xl flex items-center justify-between gap-4"
                 style="background: var(--color-bg-card); border: 1px solid var(--color-border-bright);">
              <div>
                <div class="text-xs mb-1" style="color: var(--color-text-muted); font-family: var(--font-body);">Fitness Center Monthly Range</div>
                <div class="text-2xl font-bold" style="font-family: var(--font-mono); color: var(--color-success);">$800 – $3,500+</div>
                <div class="text-xs mt-0.5" style="color: var(--color-text-muted); font-family: var(--font-body);">Varies by daily member volume</div>
              </div>
              <span class="text-xs px-2.5 py-1.5 rounded-full flex-shrink-0"
                    style="background: rgba(16,185,129,0.12); color: var(--color-success); font-family: var(--font-body); border: 1px solid rgba(16,185,129,0.25);">
                Real deployment data
              </span>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ── VIDEO SECTION ─────────────────────────────────────────── -->
    <section class="py-24" style="background: var(--color-bg-surface);">
      <div class="max-w-4xl mx-auto px-6">
        <div class="text-center mb-10">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full mb-6 text-xs font-semibold tracking-widest uppercase"
               style="background: var(--color-primary-muted); color: var(--color-accent); font-family: var(--font-body); border: 1px solid rgba(27,111,235,0.2);">
            Program Overview
          </div>
          <h2 class="text-3xl lg:text-4xl font-bold mb-4" style="font-family: var(--font-display); letter-spacing: -0.02em;">
            How It Works for Gym Owners
          </h2>
          <p class="text-lg max-w-2xl mx-auto" style="color: var(--color-text-secondary); font-family: var(--font-body);">
            A quick walkthrough of what the program is, how gyms earn, and what the qualification process looks like.
          </p>
        </div>

        <!-- Loom Video Embed -->
        <div class="relative rounded-2xl overflow-hidden"
             style="aspect-ratio: 16/9; box-shadow: 0 12px 48px rgba(0,0,0,0.45); border: 1px solid var(--color-border-bright);">
          <iframe
            src="https://www.loom.com/embed/9abddd0b39b5412babe1b286896460e1?hide_owner=true&hide_share=true&hide_title=true&hideEmbedTopBar=true"
            frameborder="0"
            allowfullscreen
            class="absolute inset-0 w-full h-full"
            title="Mobile Offload for Gym Owners — Video Explainer"
          ></iframe>
        </div>
        </div>
      </div>
    </section>

    <!-- ── GYM EARNINGS CALCULATOR ───────────────────────────────── -->
    <section id="revenue" class="py-28 relative grid-texture" style="background: var(--color-bg-base);">
      <div class="max-w-7xl mx-auto px-6">

        <div class="text-center mb-16">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full mb-6 text-xs font-semibold tracking-widest uppercase"
               style="background: rgba(16,185,129,0.1); color: var(--color-success); font-family: var(--font-body); border: 1px solid rgba(16,185,129,0.25);">
            Gym Revenue Potential
          </div>
          <h2 class="text-4xl lg:text-5xl font-bold mb-6" style="font-family: var(--font-display); letter-spacing: -0.02em;">
            What Could Your<br/>
            <span class="gradient-text">Gym Earn?</span>
          </h2>
          <p class="text-lg max-w-2xl mx-auto" style="color: var(--color-text-secondary); font-family: var(--font-body);">
            Gyms rank among the highest-earning venue types because members stay 1–2 hours and stream music or video the entire time. Use the slider to estimate based on your daily check-ins.
          </p>
        </div>

        <div class="grid lg:grid-cols-2 gap-8 items-start">

          <!-- Calculator -->
          <div class="card-dark p-8">
            <h3 class="text-xl font-bold mb-2" style="font-family: var(--font-display);">Estimate Your Gym's Revenue</h3>
            <p class="text-sm mb-8" style="color: var(--color-text-secondary); font-family: var(--font-body);">
              Based on 1–2 hour workout sessions with active music, podcast, and video streaming — the primary driver of offload revenue for fitness locations.
            </p>

            <!-- Why gyms earn well -->
            <div class="mb-8 px-4 py-3 rounded-xl flex items-start gap-3" style="background: rgba(16,185,129,0.07); border: 1px solid rgba(16,185,129,0.2);">
              <svg class="mt-0.5 flex-shrink-0" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-success)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 8v4"/><path d="M12 16h.01"/></svg>
              <span class="text-xs" style="color: var(--color-text-secondary); font-family: var(--font-body);">
