            <div class="mb-6">
              <label for="g-locations" class="block text-xs font-semibold mb-2" style="color: var(--color-text-muted); font-family: var(--font-body);">How Many Locations? *</label>
              <select id="g-locations" name="num_locations" required class="gym-input w-full px-4 py-3 rounded-xl text-sm cursor-pointer">
                <option value="">Select...</option>
