                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke={i === 0 ? 'white' : i === 1 ? '#10B981' : '#0EA5E9'} stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <Fragment set:html={item.icon} />
