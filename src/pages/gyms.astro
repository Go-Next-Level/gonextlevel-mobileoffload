              <div class="text-7xl font-bold mb-6 leading-none" style={`font-family: var(--font-mono); color: ${i === 3 ? 'var(--color-success)' : 'var(--color-border-bright)'}; line-height: 1;`}>{step.num}</div>
              <h3 class="text-lg font-bold mb-3" style="font-family: var(--font-display);">{step.title}</h3>
