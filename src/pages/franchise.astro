<script>
  const franchiseForm = document.getElementById('franchise-form');
  const franchiseSuccess = document.getElementById('franchise-form-success');
  const franchiseError = document.getElementById('franchise-form-error');

  franchiseForm?.addEventListener('submit', async (event) => {
    event.preventDefault();

    if (!(franchiseForm instanceof HTMLFormElement)) return;
    const submitButton = franchiseForm.querySelector('button[type="submit"]');

    if (submitButton instanceof HTMLButtonElement) {
      submitButton.disabled = true;
      submitButton.textContent = 'Submitting...';
    }

    franchiseError?.setAttribute('hidden', '');
    franchiseSuccess?.setAttribute('hidden', '');

    try {
      const response = await fetch(franchiseForm.action, {
        method: 'POST',
        body: new FormData(franchiseForm),
      });

      const data = await response.json().catch(() => ({ success: response.ok }));

      if (!response.ok || data.success === false) {
        throw new Error('Form submission failed');
      }

      franchiseForm.reset();
      franchiseSuccess?.removeAttribute('hidden');
      franchiseSuccess?.scrollIntoView({ behavior: 'smooth', block: 'center' });
    } catch {
      franchiseError?.removeAttribute('hidden');
    } finally {
      if (submitButton instanceof HTMLButtonElement) {
        submitButton.disabled = false;
        submitButton.textContent = 'Check My Locations';
      }
    }
  });
</script>
