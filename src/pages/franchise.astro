---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import HowItWorks from '../components/HowItWorks.astro';
import NetworkAnimation from '../components/NetworkAnimation.astro';
import CaseStudies from '../components/CaseStudies.astro';
import Security from '../components/Security.astro';
import PartnershipTerms from '../components/PartnershipTerms.astro';
import FAQ from '../components/FAQ.astro';
import QualifyForm from '../components/QualifyForm.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const title = 'Franchise Wi-Fi Revenue Audit | Mobile Offload';
const description = 'Own 20+ franchise locations? Mobile Offload helps multi-location businesses find out whether their existing Wi-Fi can generate monthly revenue through carrier offload.';
const canonicalURL = 'https://mobileoffload.com/franchise';

const revenueRows = [
  {
    type: 'Restaurants & QSR',
    why: 'Short visits, steady daily traffic, social media, ordering apps, and navigation use.',
    annual: '$21,000',
  },
  {
    type: 'Fitness Centers',
    why: '1-2 hour sessions with music, video, podcasts, and repeat weekly visits.',
    annual: '$42,000',
  },
  {
    type: 'Hotels & Convention Centers',
    why: 'Overnight stays, all-day events, video calls, streaming, and business travel.',
    annual: '$211,000',
  },
  {
    type: 'Shopping Centers',
    why: 'Longer dwell time, high concurrent device count, browsing, social media, and maps.',
    annual: '$264,000',
  },
  {
    type: 'Music & Sporting Venues',
    why: 'Thousands of devices, event-day bursts, video sharing, messaging, and live social usage.',
    annual: '$264,000',
  },
  {
    type: 'Airport Terminals',
    why: 'Long waits, heavy streaming, work calls, video calls, and high traveler volume.',
    annual: '$317,000',
  },
];

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Service',
      name: 'Franchise Wi-Fi Revenue Audit',
      provider: {
        '@type': 'Organization',
        name: 'Mobile Offload',
        url: 'https://mobileoffload.com',
      },
      areaServed: 'United States',
      description,
      serviceType: 'Carrier offload revenue audit for multi-location businesses',
      audience: {
        '@type': 'BusinessAudience',
        audienceType: 'Franchise owners and multi-location business operators',
      },
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Home',
          item: 'https://mobileoffload.com/',
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: 'Franchise Wi-Fi Revenue Audit',
          item: canonicalURL,
        },
      ],
    },
  ],
};
---

<Base title={title} description={description} canonicalURL={canonicalURL}>
  <main id="main">
    <Nav />
    <Hero
      badge="Franchise Wi-Fi Revenue Audit"
      titleLine1="Own 20+ Locations?"
      titleHighlight="Turn Existing Wi-Fi"
      titleLine3="Into Monthly Revenue"
      description="Mobile Offload helps multi-location businesses monetize eligible mobile data usage through their existing Wi-Fi infrastructure - without changing the customer experience."
      primaryCta="Check If My Locations Qualify"
      secondaryCta="See Revenue Potential"
      secondaryHref="#revenue"
    />

    <section id="revenue" class="py-28 relative grid-texture" style="background: var(--color-bg-base);">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-16">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full mb-6 text-xs font-semibold tracking-widest uppercase"
               style="background: rgba(16,185,129,0.1); color: var(--color-success); font-family: var(--font-body); border: 1px solid rgba(16,185,129,0.25);">
            Revenue Potential
          </div>
          <h2 class="text-4xl lg:text-5xl font-bold mb-6" style="font-family: var(--font-display); letter-spacing: -0.02em;">
            Do You Own 20+<br/>
            <span class="gradient-text">Franchise Locations?</span>
          </h2>
          <p class="text-lg max-w-3xl mx-auto" style="color: var(--color-text-secondary); font-family: var(--font-body); line-height: 1.7;">
            Revenue potential depends on traffic, dwell time, Wi-Fi quality, carrier needs in your area, and eligible data usage. The examples below show annual potential per location type, per location. They are not guarantees.
          </p>
        </div>

        <div class="grid lg:grid-cols-[0.75fr_1.25fr] gap-8 items-start">
          <div class="card-dark p-8">
            <h3 class="text-2xl font-bold mb-4" style="font-family: var(--font-display);">Portfolio math can add up quickly.</h3>
            <p class="text-sm mb-6" style="color: var(--color-text-secondary); font-family: var(--font-body); line-height: 1.7;">
              One location may be interesting. A 20, 50, or 100-location portfolio is where this can become meaningful. Mobile Offload reviews your locations, traffic profile, and existing Wi-Fi to see whether your group may qualify.
            </p>
            <div class="p-5 rounded-xl mb-6" style="background: var(--color-primary-muted); border: 1px solid rgba(27,111,235,0.25);">
              <div class="text-xs font-semibold tracking-widest uppercase mb-2" style="color: var(--color-accent); font-family: var(--font-body);">Best Fit</div>
              <p class="text-sm" style="color: var(--color-text-secondary); font-family: var(--font-body); line-height: 1.7;">
                20+ locations with consistent foot traffic. Some 10+ location groups may also qualify.
              </p>
            </div>
            <a href="#qualify" class="inline-flex items-center justify-center gap-2 px-7 py-4 rounded-xl text-base font-semibold text-white transition-all duration-200 cursor-pointer"
               style="background: var(--color-primary); font-family: var(--font-body);"
               onmouseover="this.style.background='var(--color-primary-hover)'"
               onmouseout="this.style.background='var(--color-primary)'">
              Request a Wi-Fi Revenue Audit
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>

          <div class="rounded-2xl overflow-hidden" style="border: 1px solid var(--color-border);">
            <table class="w-full" role="table">
              <caption class="sr-only">Annual revenue potential by location type, per location</caption>
              <thead>
                <tr style="background: var(--color-bg-elevated); border-bottom: 1px solid var(--color-border);">
                  <th scope="col" class="text-left px-6 py-4 text-sm font-semibold" style="color: var(--color-text-secondary); font-family: var(--font-display);">Location Type</th>
                  <th scope="col" class="hidden md:table-cell text-left px-6 py-4 text-sm font-semibold" style="color: var(--color-text-secondary); font-family: var(--font-display);">Why It Earns</th>
                  <th scope="col" class="text-right px-6 py-4 text-sm font-semibold" style="color: var(--color-text-secondary); font-family: var(--font-display);">Annual Potential</th>
                </tr>
              </thead>
              <tbody>
                {revenueRows.map((row, i) => (
                  <tr style={`background: ${i % 2 === 0 ? 'var(--color-bg-surface)' : 'var(--color-bg-base)'}; border-bottom: 1px solid var(--color-border);`}>
                    <td class="px-6 py-4 text-sm font-medium" style="font-family: var(--font-body); color: var(--color-text-primary);">{row.type}</td>
                    <td class="hidden md:table-cell px-6 py-4 text-sm" style="color: var(--color-text-muted); font-family: var(--font-body); line-height: 1.55;">{row.why}</td>
                    <td class="px-6 py-4 text-right font-bold whitespace-nowrap" style="font-family: var(--font-mono); color: var(--color-text-primary);">
                      {row.annual}
                      <span class="block text-xs font-normal mt-1" style="color: var(--color-text-muted); font-family: var(--font-body);">/yr per location</span>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>

        <p class="text-xs mt-6 text-center max-w-3xl mx-auto" style="color: var(--color-text-muted); font-family: var(--font-body); line-height: 1.7;">
          These are example categories based on deployment-style assumptions and public-facing venue patterns. Actual revenue depends on location count, traffic, carrier mix, local network demand, eligible offloaded data, and final qualification.
        </p>
      </div>
    </section>

    <HowItWorks />
    <NetworkAnimation />
    <CaseStudies />
    <Security />
    <PartnershipTerms />
    <FAQ />
    <QualifyForm />
    <Footer />
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </main>
</Base>
