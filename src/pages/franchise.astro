---
import Base from '../layouts/Base.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const title = 'Franchise Wi-Fi Revenue Audit | Mobile Offload';
const description = 'Own 20+ franchise locations? Mobile Offload helps multi-location businesses find out whether their existing Wi-Fi can generate monthly revenue through carrier offload.';
const canonicalURL = 'https://mobileoffload.com/franchise';

const businessTypes = [
  'Restaurant / QSR',
  'Gym / Fitness',
  'Retail Chain',
  'Hotel / Hospitality',
  'Car Wash',
  'Laundromat',
  'Entertainment Venue',
  'Urgent Care / Healthcare',
  'Franchise Group',
  'Other',
];

const visitorRanges = [
  'Under 100',
  '100-250',
  '250-500',
  '500-1,000',
  '1,000-2,500',
  '2,500+',
  'Not Sure',
];

const steps = [
  {
    title: 'Customers enter your location',
    body: 'Their mobile devices are already using data while they visit.',
  },
  {
    title: 'Eligible devices connect automatically',
    body: 'Supported carrier devices can securely route data through an approved Wi-Fi offload connection in the background.',
  },
  {
    title: 'Usage is measured',
    body: 'Eligible carrier data usage is tracked across participating locations.',
  },
  {
    title: 'Your business earns monthly revenue',
    body: 'Qualified businesses can receive recurring revenue based on eligible offloaded data.',
  },
];

const checklist = [
  '10+ physical locations',
  'High daily customer traffic',
  'Existing commercial Wi-Fi',
  'Customers who spend time on-site',
  'Locations where better indoor mobile connectivity may matter',
  'Interest in creating new recurring revenue without adding another product or service',
];

const objections = [
  'No customer app to download',
  'No loyalty program to manage',
  'No coupons or promotions',
  'No new checkout process',
  'No staff training required',
  'No disruption to your normal customer experience',
];

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Service',
      name: 'Franchise Wi-Fi Revenue Audit',
      provider: {
        '@type': 'Organization',
        name: 'Mobile Offload',
        url: 'https://mobileoffload.com',
      },
      areaServed: 'United States',
      description,
      serviceType: 'Carrier offload revenue audit for multi-location businesses',
      audience: {
        '@type': 'BusinessAudience',
        audienceType: 'Franchise owners and multi-location business operators',
      },
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Home',
          item: 'https://mobileoffload.com/',
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: 'Franchise Wi-Fi Revenue Audit',
          item: canonicalURL,
        },
      ],
    },
  ],
};
---

<Base title={title} description={description} canonicalURL={canonicalURL}>
  <main id="main" class="franchise-page">
    <header class="franchise-nav">
      <nav class="franchise-nav__inner" aria-label="Franchise page navigation">
        <a href="/" class="franchise-brand" aria-label="Mobile Offload home">
          <span class="franchise-brand__mark" aria-hidden="true">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none">
              <path d="M5 12.55a11 11 0 0 1 14.08 0" stroke="white" stroke-width="2" stroke-linecap="round"/>
              <path d="M1.42 9a16 16 0 0 1 21.16 0" stroke="white" stroke-width="2" stroke-linecap="round"/>
              <path d="M8.53 16.11a6 6 0 0 1 6.95 0" stroke="white" stroke-width="2" stroke-linecap="round"/>
              <circle cx="12" cy="20" r="1" fill="white"/>
            </svg>
          </span>
          <span>Mobile<span>Offload</span></span>
        </a>

        <div class="franchise-nav__links">
          <a href="#how-it-works">How It Works</a>
          <a href="#fit">Who Qualifies</a>
          <a href="#qualify">Audit Form</a>
        </div>

        <a href="#qualify" class="franchise-nav__cta">Check Eligibility</a>
      </nav>
    </header>

    <section class="franchise-hero" aria-label="Franchise Wi-Fi Revenue Audit">
      <div class="franchise-hero__glow" aria-hidden="true"></div>
      <div class="franchise-shell franchise-hero__grid">
        <div class="franchise-hero__copy">
          <p class="franchise-kicker">Franchise Wi-Fi Revenue Audit</p>
          <h1>Own 20+ Franchise Locations? Your Existing Wi-Fi Could Become a Monthly Revenue Stream.</h1>
          <p class="franchise-hero__lead">Mobile Offload helps multi-location businesses monetize eligible mobile data usage through their existing Wi-Fi infrastructure - without changing the customer experience.</p>
          <div class="franchise-actions">
            <a href="#qualify" class="franchise-button franchise-button--primary">
              Check If My Locations Qualify
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
            <a href="#how-it-works" class="franchise-button franchise-button--secondary">See How It Works</a>
          </div>
          <p class="franchise-trust">Built for restaurants, gyms, retail chains, hotels, car washes, laundromats, entertainment venues, and franchise groups.</p>
        </div>
      </div>
    </section>

    <section class="franchise-section" id="simple">
      <div class="franchise-shell franchise-narrow">
        <p class="franchise-kicker">Simple idea</p>
        <h2>Your customers already use mobile data inside your locations. You may just not be getting paid for it.</h2>
        <div class="franchise-copy-stack">
          <p>Every day, customers walk into your locations with phones in their pockets. They scroll, stream, message, browse, order, check email, and use apps while they are inside your business.</p>
          <p>That mobile data creates demand on nearby cellular towers.</p>
          <p>Carrier offload allows eligible mobile data to securely move through approved Wi-Fi networks instead. This helps carriers reduce tower congestion and improve indoor connectivity.</p>
          <p>Your business may be able to get paid for helping support that network.</p>
        </div>
      </div>
    </section>

    <section class="franchise-section franchise-section--surface" id="how-it-works">
      <div class="franchise-shell">
        <div class="franchise-section__head">
          <p class="franchise-kicker">The process</p>
          <h2>How Mobile Offload Works</h2>
        </div>
        <div class="franchise-steps">
          {steps.map((step, index) => (
            <article class="franchise-step-card">
              <span class="franchise-step-card__num">{String(index + 1).padStart(2, '0')}</span>
              <h3>{step.title}</h3>
              <p>{step.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="franchise-section" id="fit">
      <div class="franchise-shell franchise-fit-grid">
        <div>
          <p class="franchise-kicker">Best fit</p>
          <h2>Why this works especially well for franchise owners</h2>
          <div class="franchise-copy-stack">
            <p>This is not designed for one small office with a few visitors a day.</p>
            <p>Mobile Offload works best when you have multiple locations, consistent customer traffic, reliable Wi-Fi, and customers who spend time on-site.</p>
          </div>
        </div>
        <div class="franchise-check-panel">
          <ul>
            {checklist.map((item) => (
              <li>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-success)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                <span>{item}</span>
              </li>
            ))}
          </ul>
          <div class="franchise-callout">
            <strong>Best fit:</strong> 20+ locations with consistent foot traffic. Some 10+ location groups may also qualify.
          </div>
        </div>
      </div>
    </section>

    <section class="franchise-section franchise-worth" id="worth">
      <div class="franchise-shell franchise-worth__grid">
        <div>
          <p class="franchise-kicker">Revenue potential</p>
          <h2>What could your locations be worth?</h2>
        </div>
        <div class="franchise-worth__body">
          <p>Revenue potential depends on your location count, foot traffic, customer dwell time, Wi-Fi quality, carrier needs in your area, and eligible data usage.</p>
          <p>For larger qualified operators, this can potentially become a meaningful monthly revenue opportunity across the full portfolio.</p>
          <a href="#qualify" class="franchise-button franchise-button--primary">Request a Wi-Fi Revenue Audit</a>
        </div>
      </div>
    </section>

    <section class="franchise-section franchise-section--surface" id="quiet">
      <div class="franchise-shell franchise-objection-grid">
        <div>
          <p class="franchise-kicker">Built to stay simple</p>
          <h2>No customer app. No staff training. No disruption.</h2>
          <p>Mobile Offload works quietly in the background using infrastructure your business may already have.</p>
        </div>
        <ul class="franchise-objections">
          {objections.map((item) => (
            <li>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14"/><path d="M5 12h14"/></svg>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <section class="franchise-section" id="qualify">
      <div class="franchise-shell franchise-form-grid">
        <div class="franchise-form-copy">
          <p class="franchise-kicker">Qualification form</p>
          <h2>Find Out If Your Locations Qualify</h2>
          <p>You may already have the infrastructure.<br />You may already have the traffic.<br />You may just not be monetizing it yet.</p>
          <div class="franchise-form-copy__mini">
            <strong>What happens next?</strong>
            <span>Our team reviews your business, location count, Wi-Fi profile, and traffic fit. If it looks like a match, we follow up with next steps.</span>
          </div>
        </div>

        <form id="franchise-form" class="franchise-form" action="https://api.web3forms.com/submit" method="POST">
          <input type="hidden" name="access_key" value={import.meta.env.WEB3FORMS_KEY} />
          <input type="hidden" name="subject" value="Mobile Offload Franchise Wi-Fi Revenue Audit" />
          <input type="hidden" name="from_name" value="Mobile Offload Franchise Page" />
          <input type="hidden" name="redirect" value="https://mobileoffload.com/thank-you" />
          <input type="checkbox" name="botcheck" class="franchise-botcheck" tabindex="-1" autocomplete="off" />

          <div class="franchise-form__grid">
            <label>
              <span>First Name</span>
              <input type="text" name="first_name" autocomplete="given-name" required />
            </label>
            <label>
              <span>Last Name</span>
              <input type="text" name="last_name" autocomplete="family-name" required />
            </label>
            <label>
              <span>Email</span>
              <input type="email" name="email" autocomplete="email" required />
            </label>
            <label>
              <span>Phone</span>
              <input type="tel" name="phone" autocomplete="tel" required />
            </label>
            <label>
              <span>Company Name</span>
              <input type="text" name="company_name" autocomplete="organization" required />
            </label>
            <label>
              <span>Website</span>
              <input type="url" name="website" autocomplete="url" placeholder="https://" />
            </label>
            <label>
              <span>Business Type</span>
              <select name="business_type" required>
                <option value="">Select...</option>
                {businessTypes.map((type) => <option value={type}>{type}</option>)}
              </select>
            </label>
            <label>
              <span>Number of Locations</span>
              <select name="number_of_locations" required>
                <option value="">Select...</option>
                <option value="1-9">1-9</option>
                <option value="10-19">10-19</option>
                <option value="20-49">20-49</option>
                <option value="50-99">50-99</option>
                <option value="100+">100+</option>
              </select>
            </label>
            <label>
              <span>Approximate Daily Visitors Per Location</span>
              <select name="daily_visitors_per_location" required>
                <option value="">Select...</option>
                {visitorRanges.map((range) => <option value={range}>{range}</option>)}
              </select>
            </label>
            <fieldset>
              <legend>Do You Currently Offer Customer Wi-Fi?</legend>
              <div class="franchise-radio-row">
                <label><input type="radio" name="customer_wifi" value="Yes" required /> <span>Yes</span></label>
                <label><input type="radio" name="customer_wifi" value="No" /> <span>No</span></label>
                <label><input type="radio" name="customer_wifi" value="Not Sure" /> <span>Not Sure</span></label>
              </div>
            </fieldset>
            <label class="franchise-form__full">
              <span>Anything else we should know?</span>
              <textarea name="message" rows="4"></textarea>
            </label>
          </div>

          <button class="franchise-form__submit" type="submit">Check My Locations</button>
          <p class="franchise-form__fineprint">By submitting, you agree that Mobile Offload may contact you about your audit request. Not every business qualifies.</p>

          <div id="franchise-form-success" class="franchise-form__success" role="status" aria-live="polite" hidden>
            Thanks - we received your request. Our team will review your business and follow up if your locations may qualify for Mobile Offload.
          </div>
          <div id="franchise-form-error" class="franchise-form__error" role="alert" hidden>
            Something went wrong. Please try again or email corey@mobileoffload.com.
          </div>
        </form>
      </div>
    </section>

    <section class="franchise-final-cta">
      <div class="franchise-shell">
        <p class="franchise-kicker">Final check</p>
        <h2>Your locations may already be creating value for mobile carriers.</h2>
        <p>Mobile Offload helps you find out whether that value can become monthly revenue for your business.</p>
        <a href="#qualify" class="franchise-button franchise-button--primary">Check If My Locations Qualify</a>
      </div>
    </section>

    <Footer />
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </main>
</Base>

<style>
  .franchise-page {
    background:
      radial-gradient(900px 520px at 85% 10%, rgba(27, 111, 235, 0.18), transparent 68%),
      radial-gradient(620px 420px at 8% 30%, rgba(14, 165, 233, 0.1), transparent 70%),
      var(--color-bg-base);
  }

  .franchise-shell {
    width: min(1120px, calc(100% - 32px));
    margin: 0 auto;
  }

  .franchise-nav {
    position: fixed;
    inset: 0 0 auto;
    z-index: 60;
    background: rgba(4, 7, 15, 0.94);
    border-bottom: 1px solid rgba(27, 111, 235, 0.14);
    backdrop-filter: blur(24px);
  }

  .franchise-nav__inner {
    width: min(1120px, calc(100% - 32px));
    min-height: 64px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }

  .franchise-brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    min-height: 44px;
    color: var(--color-text-primary);
    font-family: var(--font-display);
    font-size: 1.06rem;
    font-weight: 700;
    text-decoration: none;
  }

  .franchise-brand > span:last-child span {
    color: var(--color-primary);
  }

  .franchise-brand__mark {
    width: 34px;
    height: 34px;
    border-radius: 10px;
    display: inline-grid;
    place-items: center;
    background: linear-gradient(135deg, #1B6FEB, #0EA5E9);
    box-shadow: 0 10px 32px rgba(27, 111, 235, 0.28);
  }

  .franchise-nav__links {
    display: none;
    align-items: center;
    gap: 24px;
  }

  .franchise-nav__links a,
  .franchise-nav__cta {
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    color: var(--color-text-secondary);
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    transition: color 0.2s ease, border-color 0.2s ease, background 0.2s ease;
  }

  .franchise-nav__links a:hover {
    color: var(--color-text-primary);
  }

  .franchise-nav__cta {
    display: none;
    padding: 0 18px;
    border: 1px solid rgba(27, 111, 235, 0.45);
    border-radius: 10px;
    color: white;
    background: rgba(27, 111, 235, 0.2);
  }

  .franchise-nav__cta:hover {
    border-color: var(--color-primary);
    background: var(--color-primary);
  }

  .franchise-hero {
    position: relative;
    min-height: 100svh;
    padding: 116px 0 72px;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .franchise-hero__glow {
    position: absolute;
    inset: 64px 0 auto;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(14, 165, 233, 0.8), transparent);
  }

  .franchise-hero__grid {
    position: relative;
    display: grid;
    justify-items: center;
    text-align: center;
  }

  .franchise-hero__copy {
    width: min(100%, 940px);
  }

  .franchise-kicker {
    margin: 0 0 18px;
    color: var(--color-accent);
    font-family: var(--font-body);
    font-size: 0.74rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    line-height: 1.4;
    text-transform: uppercase;
  }

  .franchise-hero h1,
  .franchise-section h2,
  .franchise-final-cta h2 {
    margin: 0;
    max-width: 820px;
    font-family: var(--font-display);
    letter-spacing: 0;
  }

  .franchise-hero h1 {
    font-size: clamp(2.55rem, 8.2vw, 5.6rem);
    line-height: 0.96;
  }

  .franchise-hero__lead {
    max-width: 680px;
    margin: 24px auto 0;
    color: var(--color-text-secondary);
    font-size: clamp(1.05rem, 2.8vw, 1.28rem);
    line-height: 1.62;
  }

  .franchise-actions {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    justify-content: center;
    gap: 12px;
    margin-top: 34px;
  }

  .franchise-button {
    min-height: 48px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    border-radius: 10px;
    padding: 13px 18px;
    font-family: var(--font-body);
    font-size: 0.98rem;
    font-weight: 800;
    text-align: center;
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease, background 0.2s ease, color 0.2s ease;
  }

  .franchise-button:hover {
    transform: translateY(-1px);
  }

  .franchise-button--primary {
    color: white;
    background: var(--color-primary);
    box-shadow: 0 18px 48px rgba(27, 111, 235, 0.26);
  }

  .franchise-button--primary:hover {
    background: var(--color-primary-hover);
    box-shadow: 0 22px 58px rgba(27, 111, 235, 0.34);
  }

  .franchise-button--secondary {
    color: var(--color-text-secondary);
    background: rgba(11, 20, 34, 0.66);
    border: 1px solid var(--color-border-bright);
  }

  .franchise-button--secondary:hover {
    color: var(--color-text-primary);
    border-color: var(--color-primary);
  }

  .franchise-trust {
    max-width: 740px;
    margin: 22px auto 0;
    color: var(--color-text-muted);
    font-size: 0.94rem;
    line-height: 1.6;
  }

  .franchise-section {
    padding: 76px 0;
  }

  .franchise-section--surface,
  .franchise-final-cta {
    background: rgba(11, 20, 34, 0.82);
    border-block: 1px solid rgba(22, 32, 53, 0.9);
  }

  .franchise-narrow {
    max-width: 820px;
  }

  .franchise-section h2,
  .franchise-final-cta h2 {
    font-size: clamp(2rem, 5.2vw, 3.85rem);
    line-height: 1.04;
  }

  .franchise-copy-stack {
    display: grid;
    gap: 16px;
    margin-top: 28px;
  }

  .franchise-copy-stack p,
  .franchise-worth__body p,
  .franchise-objection-grid p,
  .franchise-final-cta p,
  .franchise-form-copy > p {
    margin: 0;
    color: var(--color-text-secondary);
    font-size: 1.02rem;
    line-height: 1.72;
  }

  .franchise-section__head {
    max-width: 720px;
    margin-bottom: 34px;
  }

  .franchise-steps {
    display: grid;
    gap: 14px;
  }

  .franchise-step-card,
  .franchise-check-panel,
  .franchise-objections li,
  .franchise-form,
  .franchise-form-copy__mini {
    border: 1px solid var(--color-border);
    border-radius: 12px;
    background: rgba(16, 29, 51, 0.72);
  }

  .franchise-step-card {
    padding: 22px;
  }

  .franchise-step-card__num {
    display: block;
    margin-bottom: 28px;
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: 0.86rem;
    font-weight: 700;
  }

  .franchise-step-card h3 {
    margin: 0 0 10px;
    font-size: 1.12rem;
    letter-spacing: 0;
  }

  .franchise-step-card p {
    margin: 0;
    color: var(--color-text-secondary);
    font-size: 0.94rem;
    line-height: 1.62;
  }

  .franchise-fit-grid,
  .franchise-worth__grid,
  .franchise-objection-grid,
  .franchise-form-grid {
    display: grid;
    gap: 34px;
  }

  .franchise-check-panel {
    padding: 24px;
  }

  .franchise-check-panel ul,
  .franchise-objections {
    display: grid;
    gap: 14px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .franchise-check-panel li,
  .franchise-objections li {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    color: var(--color-text-secondary);
    font-size: 0.98rem;
    line-height: 1.55;
  }

  .franchise-check-panel li svg,
  .franchise-objections li svg {
    flex: 0 0 auto;
    margin-top: 3px;
  }

  .franchise-callout {
    margin-top: 24px;
    padding: 16px;
    border: 1px solid rgba(14, 165, 233, 0.3);
    border-radius: 10px;
    background: rgba(14, 165, 233, 0.08);
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  .franchise-callout strong {
    color: var(--color-text-primary);
  }

  .franchise-worth {
    background:
      linear-gradient(90deg, rgba(16, 185, 129, 0.09), transparent 42%),
      var(--color-bg-base);
  }

  .franchise-worth__body {
    display: grid;
    gap: 18px;
  }

  .franchise-worth__body .franchise-button {
    width: fit-content;
    margin-top: 8px;
  }

  .franchise-objections {
    grid-template-columns: 1fr;
  }

  .franchise-objections li {
    padding: 16px;
  }

  .franchise-form-copy__mini {
    display: grid;
    gap: 8px;
    margin-top: 28px;
    padding: 18px;
    color: var(--color-text-secondary);
  }

  .franchise-form-copy__mini strong {
